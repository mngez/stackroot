<Window x:Class="Stackroot.App.Views.TestDnsSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Loc.TestDns.Title}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="720"
        MinWidth="640"
        MaxWidth="860"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="{DynamicResource Loc.TestDns.Title}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{DynamicResource Loc.TestDns.Subtitle}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,16,0,0" IsEnabled="{Binding IsIdle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <CheckBox Content="{DynamicResource Loc.Common.Enabled}"
                          IsChecked="{Binding Enabled}" />
                <TextBlock Margin="24,6,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           FontSize="12"
                           Text="{DynamicResource Loc.TestDns.EnabledHint}"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,14,0,4"
                           Text="{DynamicResource Loc.TestDns.ResolveIp}" />
                <TextBox FontFamily="Consolas"
                         FontSize="12"
                         MaxLength="45"
                         FlowDirection="LeftToRight"
                         Text="{Binding ResolveAddress, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           FontSize="12"
                           Text="{DynamicResource Loc.TestDns.ResolveIpHint}"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{StaticResource StackrootDangerBrush}"
                           FontSize="12"
                           Text="{Binding ResolveAddressError}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <CheckBox Content="{DynamicResource Loc.TestDns.AutoStart}"
                          IsChecked="{Binding AutoStart}" />
                <CheckBox Margin="0,12,0,0"
                          Content="{DynamicResource Loc.TestDns.LogQueries}"
                          IsChecked="{Binding LogRequests}" />
                <TextBlock Margin="24,6,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           FontSize="12"
                           Text="{DynamicResource Loc.TestDns.LogQueriesHint}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <Expander Grid.Row="2"
                  Margin="0,16,0,0"
                  Header="{DynamicResource Loc.TestDns.SuffixesHeader}"
                  IsExpanded="False"
                  IsEnabled="{Binding IsIdle}">
            <StackPanel Margin="0,8,0,0">
                <Border Margin="0,0,0,12"
                        Padding="12"
                        Background="#33E88A92"
                        BorderBrush="{StaticResource StackrootDangerBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding PowerUserModeEnabled, Converter={StaticResource BoolToVis}}">
                    <TextBlock Foreground="{StaticResource StackrootDangerTextBrush}"
                               FontSize="12"
                               LineHeight="18"
                               Text="Power-user mode is enabled in settings.json (testDns.allowDangerousSettings). Catch-all suffix &quot;.&quot; is allowed and requires confirmation before save."
                               TextWrapping="Wrap" />
                </Border>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" MinWidth="240" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" MinWidth="240" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{DynamicResource Loc.TestDns.SuffixesLabel}"
                               TextWrapping="Wrap" />
                    <TextBox Margin="0,8,0,0"
                             MinHeight="72"
                             MaxHeight="120"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="12"
                             FlowDirection="LeftToRight"
                             Text="{Binding SuffixesText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               FontSize="12"
                               Text="{DynamicResource Loc.TestDns.SuffixesHint}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource StackrootDangerBrush}"
                               FontSize="12"
                               Text="{Binding SuffixesError}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource StackrootDangerBrush}"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Text="{Binding DangerousSuffixWarning}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Padding="12"
                            Background="#33E88A92"
                            BorderBrush="{StaticResource StackrootDangerBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{StaticResource StackrootDangerBrush}"
                                       Text="{DynamicResource Loc.TestDns.IfInternetStops}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{StaticResource StackrootDangerTextBrush}"
                                       FontSize="12"
                                       LineHeight="18"
                                       TextWrapping="Wrap">
                                <Run Text="NRPT may still send matching names to 127.0.0.1 after a crash or failed save. First: turn off " />
                                <Run FontWeight="SemiBold" Text="Enabled" />
                                <Run Text=" and click " />
                                <Run FontWeight="SemiBold" Text="Save" />
                                <Run Text=". If that fails, copy the command below and run it in " />
                                <Run FontWeight="SemiBold" Text="Administrator PowerShell" />
                                <Run Text="." />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Margin="0,12,0,6"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               FontSize="12"
                               Text="{DynamicResource Loc.TestDns.RecoveryHint}"
                               TextWrapping="Wrap" />
                    <TextBox MinHeight="52"
                             MaxHeight="72"
                             Padding="8,6"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             FontSize="11"
                             FlowDirection="LeftToRight"
                             Text="{Binding RecoveryCommandText, Mode=OneWay}" />
                    <Button Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            MinWidth="140"
                            Padding="12,6"
                            Content="{DynamicResource Loc.TestDns.CopyCleanup}"
                            Command="{Binding CopyRecoveryCommand}" />
                </StackPanel>
            </Grid>
            </StackPanel>
        </Expander>

        <StackPanel Grid.Row="3" Margin="0,18,0,0">
            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       MinHeight="16"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
            <DockPanel Margin="0,12,0,0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="88"
                            Margin="0,0,8,0"
                            Content="{DynamicResource Loc.Common.Close}"
                            Command="{Binding CloseCommand}" />
                    <Button Width="88"
                            Style="{StaticResource StackrootPrimaryButtonStyle}"
                            Command="{Binding SaveCommand}"
                            Content="{Binding SaveButtonText}" />
                </StackPanel>
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
