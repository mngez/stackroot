<Window x:Class="Stackroot.App.Views.TestDnsSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Test DNS settings"
        Width="460"
        MinWidth="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="Test DNS settings" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Routes only .test names to Stackroot DNS on 127.0.0.1:53. Supports wildcards like *.app.test. Other domains and internet traffic are unchanged."
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,16,0,0" IsEnabled="{Binding IsIdle}">
            <CheckBox Content="Enabled"
                      IsChecked="{Binding Enabled}" />
            <TextBlock Margin="24,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       Text="May require administrator approval once for the Windows NRPT routing rule."
                       TextWrapping="Wrap" />
            <CheckBox Margin="0,16,0,0"
                      Content="Start automatically with Stackroot"
                      IsChecked="{Binding AutoStart}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       MinHeight="16"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
            <DockPanel Margin="0,12,0,0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="88"
                            Margin="0,0,8,0"
                            Content="Close"
                            Command="{Binding CloseCommand}" />
                    <Button Width="88"
                            Style="{StaticResource StackrootPrimaryButtonStyle}"
                            Command="{Binding SaveCommand}"
                            Content="{Binding SaveButtonText}" />
                </StackPanel>
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
