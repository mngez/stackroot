<Window x:Class="Stackroot.App.Views.DevSslPathsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:Stackroot.App.Windows"
        Title="Local SSL paths"
        Width="620"
        MinWidth="520"
        SizeToContent="Height"
        MaxHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False"
        windows:WindowsTheme.EnableDarkTitleBar="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="Local SSL paths" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Stackroot dev certificate files (PEM). Use these paths in Node servers or your .env."
                       TextWrapping="Wrap" />
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Margin="0,16,0,6"
                   Foreground="{StaticResource StackrootTextMutedBrush}"
                   Text="Certificate (dev.crt)" />
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Padding="10,6"
                     FontFamily="Consolas"
                     FontSize="12"
                     IsReadOnly="True"
                     Text="{Binding CertificatePath, Mode=OneWay}" />
            <Button Grid.Column="1"
                    MinWidth="72"
                    Margin="8,0,0,0"
                    Padding="10,6"
                    Content="Copy"
                    Command="{Binding CopyCertificateCommand}" />
        </Grid>

        <TextBlock Grid.Row="3"
                   Margin="0,14,0,6"
                   Foreground="{StaticResource StackrootTextMutedBrush}"
                   Text="Private key (dev.key)" />
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Padding="10,6"
                     FontFamily="Consolas"
                     FontSize="12"
                     IsReadOnly="True"
                     Text="{Binding PrivateKeyPath, Mode=OneWay}" />
            <Button Grid.Column="1"
                    MinWidth="72"
                    Margin="8,0,0,0"
                    Padding="10,6"
                    Content="Copy"
                    Command="{Binding CopyPrivateKeyCommand}" />
        </Grid>

        <StackPanel Grid.Row="5"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button MinWidth="100"
                    Content="Close"
                    Command="{Binding CloseCommand}" />
        </StackPanel>
    </Grid>
</Window>
