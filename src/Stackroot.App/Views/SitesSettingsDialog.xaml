<Window x:Class="Stackroot.App.Views.SitesSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Loc.SiteSettings.Title}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="460"
        MinWidth="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="{DynamicResource Loc.SiteSettings.Title}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{DynamicResource Loc.SiteSettings.Subtitle}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <CheckBox Content="{DynamicResource Loc.SiteSettings.AutoHosts}"
                      IsChecked="{Binding AutoHosts}" />
            <TextBlock Margin="24,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       Text="{DynamicResource Loc.SiteSettings.AutoHostsHint}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       MinHeight="16"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
            <DockPanel Margin="0,12,0,0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="88"
                            Margin="0,0,8,0"
                            Content="{DynamicResource Loc.Common.Close}"
                            Command="{Binding CloseCommand}" />
                    <Button Width="88"
                            Content="{DynamicResource Loc.Common.Save}"
                            Style="{StaticResource StackrootPrimaryButtonStyle}"
                            Command="{Binding SaveCommand}" />
                </StackPanel>
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
