<Window x:Class="Stackroot.App.Views.SitesSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sites settings"
        Width="460"
        MinWidth="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="Sites settings" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Control how Stackroot manages local domain resolution."
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <CheckBox Content="Automatically update Windows hosts file for enabled domains"
                      IsChecked="{Binding AutoHosts}" />
            <TextBlock Margin="24,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       Text="When enabled, Stackroot writes 127.0.0.1 entries for your local domains. Requires administrator privileges if access is denied."
                       TextWrapping="Wrap" />

            <CheckBox Margin="0,16,0,0"
                      Content="Resolve .test domains locally (wildcard DNS)"
                      IsChecked="{Binding TestDnsEnabled}" />
            <TextBlock Margin="24,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       Text="Optional. Routes only .test names to Stackroot DNS on 127.0.0.1. Supports wildcards like *.app.test. Other domains and internet traffic are unchanged. Disabled by default; may require administrator approval once."
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       MinHeight="16"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
            <DockPanel Margin="0,12,0,0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="88"
                            Margin="0,0,8,0"
                            Content="Close"
                            Command="{Binding CloseCommand}" />
                    <Button Width="88"
                            Content="Save"
                            Style="{StaticResource StackrootPrimaryButtonStyle}"
                            Command="{Binding SaveCommand}" />
                </StackPanel>
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
