<Window x:Class="Stackroot.App.Views.PhpExtensionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding VersionLabel, StringFormat=Extensions — {0}}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="680"
        MinWidth="560"
        Height="560"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="{Binding VersionLabel, StringFormat=Extensions — {0}}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{DynamicResource Loc.PhpExtensions.Subtitle}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBox Width="220"
                     Margin="0,0,8,8"
                     Padding="10,6"
                     Tag="Search extensions…"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="{DynamicResource Loc.PhpExtensions.FilterTooltip}" />
            <Button Margin="0,0,8,8"
                    Padding="10,4"
                    Content="{DynamicResource Loc.PhpExtensions.EnableAllReady}"
                    Command="{Binding EnableAllReadyCommand}" />
            <Button Margin="0,0,8,8"
                    Padding="10,4"
                    Content="{DynamicResource Loc.PhpExtensions.ResetToDefaults}"
                    Command="{Binding ResetExtensionsCommand}" />
            <Button Margin="0,0,8,8"
                    Padding="10,4"
                    Content="{Binding TotalCount, StringFormat=All extensions ({0})}"
                    Command="{Binding ShowAllCommand}" />
            <Button Margin="0,0,8,8"
                    Padding="10,4"
                    Content="{Binding EnabledCount, StringFormat=Active in php.ini ({0})}"
                    Command="{Binding ShowEnabledCommand}" />
        </WrapPanel>

        <ScrollViewer Grid.Row="2"
                      Margin="0,10,0,0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding Extensions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,4,4"
                                    Padding="6,4"
                                    Background="{StaticResource StackrootCardBrush}"
                                    BorderBrush="{StaticResource StackrootBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold" FontSize="12"
                                                   Text="{Binding Label}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="ToolTip" Value="{Binding Description}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Description}" Value="">
                                                            <Setter Property="ToolTip" Value="{x:Null}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              Margin="6,0,0,0"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding Enabled, Mode=OneWay}"
                                              IsEnabled="{Binding CanToggle}"
                                              Click="ExtensionToggle_Click">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="ToolTip" Value="{Binding Description}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Description}" Value="">
                                                        <Setter Property="ToolTip" Value="{x:Null}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="0,14,0,8"
                           FontWeight="SemiBold"
                           Text="{DynamicResource Loc.PhpExtensions.InstallPecl}" />
                <TextBlock Margin="0,0,0,8"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           FontSize="12"
                           Text="{DynamicResource Loc.PhpExtensions.PeclHint}"
                           TextWrapping="Wrap" />

                <ItemsControl ItemsSource="{Binding InstallablePecl}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6"
                                    Padding="10,8"
                                    Background="{StaticResource StackrootCardBrush}"
                                    BorderBrush="{StaticResource StackrootBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                                   FontSize="12"
                                                   Text="{Binding Description}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Width="76"
                                            VerticalAlignment="Center"
                                            Margin="12,0,0,0"
                                            Content="{DynamicResource Loc.Common.Install}"
                                            Command="{Binding DataContext.InstallPeclCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="3" Margin="0,14,0,0" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
            <Button DockPanel.Dock="Right"
                    Width="88"
                    Content="{DynamicResource Loc.Common.Close}"
                    Command="{Binding CloseCommand}" />
        </DockPanel>
    </Grid>
</Window>
