<Window x:Class="Stackroot.App.Views.MailpitSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Loc.Mailpit.Title}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="460"
        MinWidth="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="{DynamicResource Loc.Mailpit.Title}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       TextWrapping="Wrap">
                <Run Text="Catches SMTP on 127.0.0.1:" />
                <Run FontWeight="SemiBold" Text="{Binding SmtpPort, Mode=OneWay}" />
                <Run Text=". Inbox UI at" />
                <Run FontWeight="SemiBold" Text="{Binding AppDomain, Mode=OneWay, StringFormat={}{0}/mail}" />
                <Run Text=" (via nginx)." />
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <CheckBox Content="{DynamicResource Loc.Common.Enabled}"
                      IsChecked="{Binding Enabled}" />
            <CheckBox Margin="0,10,0,0"
                      Content="{DynamicResource Loc.Mailpit.AutoRestart}"
                      IsChecked="{Binding Supervise}" />

            <TextBlock Margin="0,16,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{DynamicResource Loc.Mailpit.SmtpPort}" />
            <TextBox Margin="0,6,0,0"
                     Padding="10,6"
                     FlowDirection="LeftToRight"
                     Text="{Binding SmtpPort, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Margin="0,16,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{DynamicResource Loc.Mailpit.WebPort}" />
            <TextBox Margin="0,6,0,0"
                     Padding="10,6"
                     FlowDirection="LeftToRight"
                     Text="{Binding WebPort, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       Text="{DynamicResource Loc.Mailpit.WebPortHint}"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       Text="{Binding InboxUrl, StringFormat=Inbox URL: {0}}"
                       TextWrapping="Wrap" />

            <CheckBox Margin="0,16,0,0"
                      Content="{DynamicResource Loc.Mailpit.AutoStart}"
                      IsChecked="{Binding AutoStart}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       MinHeight="16"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
            <DockPanel Margin="0,12,0,0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="88"
                            Margin="0,0,8,0"
                            Content="{DynamicResource Loc.Common.Close}"
                            Command="{Binding CloseCommand}" />
                    <Button Width="88"
                            Content="{DynamicResource Loc.Common.Save}"
                            Style="{StaticResource StackrootPrimaryButtonStyle}"
                            Command="{Binding SaveCommand}" />
                </StackPanel>
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
