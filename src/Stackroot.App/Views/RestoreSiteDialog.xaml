<Window x:Class="Stackroot.App.Views.RestoreSiteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:Stackroot.App.Windows"
        Title="{DynamicResource Loc.RestoreSiteDialog.Title}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="440"
        MinWidth="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False"
        windows:WindowsTheme.EnableDarkTitleBar="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="{DynamicResource Loc.RestoreSiteDialog.Title}" />
            <TextBlock Margin="0,6,0,0"
                       FontSize="13"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{Binding SiteDomain}" />
        </StackPanel>

        <!-- Backup info -->
        <Border Grid.Row="1"
                Margin="0,14,0,0"
                Padding="10,8"
                Background="{StaticResource StackrootCardBrush}"
                BorderBrush="{StaticResource StackrootBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                               FontSize="12"
                               Width="60"
                               Text="{DynamicResource Loc.RestoreSiteDialog.BackupInfoLabel}" />
                    <TextBlock FontSize="12" Text="{Binding SiteName}" />
                </StackPanel>
                <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                    <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                               FontSize="12"
                               Width="60"
                               Text="{DynamicResource Loc.RestoreSiteDialog.DateLabel}" />
                    <TextBlock FontSize="12"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{Binding BackupDate}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Warning -->
        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="10,8"
                Background="#1AE8925E"
                BorderBrush="#52E8925E"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           FontFamily="{StaticResource StackrootIconFont}"
                           FontSize="14"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource StackrootWarnBrush}"
                           Text="&#xE7BA;" />
                <TextBlock Grid.Column="1"
                           FontSize="12"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource StackrootWarnBrush}"
                           Text="{DynamicResource Loc.RestoreSiteDialog.Warning}" />
            </Grid>
        </Border>

        <!-- Options -->
        <StackPanel Grid.Row="3" Margin="0,16,0,0">
            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       Margin="0,0,0,10"
                       Text="{DynamicResource Loc.RestoreSiteDialog.RestoreLabel}" />

            <CheckBox Margin="0,0,0,8"
                      IsChecked="{Binding RestoreFiles}"
                      Visibility="{Binding HasFiles, Converter={StaticResource BoolToVis}}"
                      Content="{DynamicResource Loc.RestoreSiteDialog.RestoreFiles}" />
            <CheckBox Margin="0,0,0,8"
                      IsChecked="{Binding RestoreDatabases}"
                      Visibility="{Binding HasDatabases, Converter={StaticResource BoolToVis}}"
                      Content="{DynamicResource Loc.RestoreSiteDialog.RestoreDatabases}" />
            <CheckBox Margin="0,0,0,8"
                      IsChecked="{Binding RestoreProcesses}"
                      Visibility="{Binding HasProcesses, Converter={StaticResource BoolToVis}}"
                      Content="{DynamicResource Loc.RestoreSiteDialog.RestoreProcesses}" />
            <CheckBox Margin="0,0,0,0"
                      IsChecked="{Binding RestoreScheduledTasks}"
                      Visibility="{Binding HasScheduledTasks, Converter={StaticResource BoolToVis}}"
                      Content="{DynamicResource Loc.RestoreSiteDialog.RestoreScheduledTasks}" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="88"
                    Margin="0,0,8,0"
                    Content="{DynamicResource Loc.Common.Cancel}"
                    Command="{Binding CancelCommand}" />
            <Button Width="110"
                    Style="{StaticResource StackrootStopButtonStyle}"
                    Content="{DynamicResource Loc.RestoreSiteDialog.Restore}"
                    Command="{Binding RestoreCommand}" />
        </StackPanel>
    </Grid>
</Window>
