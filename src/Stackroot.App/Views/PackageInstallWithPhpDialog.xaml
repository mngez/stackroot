<Window x:Class="Stackroot.App.Views.PackageInstallWithPhpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Loc.PackageInstall.Title}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="480"
        MinWidth="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="20" FontWeight="SemiBold">
                <Run Text="{DynamicResource Loc.Common.Install}" />
                <Run Text=" " />
                <Run Text="{Binding PackageLabel, Mode=OneWay}" />
            </TextBlock>
            <TextBlock Margin="0,8,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{Binding RequirementText, StringFormat=Requires {0}. Choose the PHP version to use.}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Margin="0,16,0,0"
                   Foreground="{StaticResource StackrootDangerTextBrush}"
                   Text="{DynamicResource Loc.PackageInstall.NoPhp}"
                   TextWrapping="Wrap"
                   Visibility="{Binding ShowMissingPhpCatalog, Converter={StaticResource BoolToVis}}" />

        <StackPanel Grid.Row="1"
                    Margin="0,16,0,0"
                    Visibility="{Binding HasPhpOptions, Converter={StaticResource BoolToVis}}">
            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{DynamicResource Loc.PackageInstall.PhpVersion}" />
            <ComboBox Margin="0,6,0,0"
                      Padding="8,4"
                      IsEditable="False"
                      ItemsSource="{Binding PhpOptions}"
                      DisplayMemberPath="Label"
                      SelectedValuePath="Id"
                      SelectedValue="{Binding SelectedPhpPackageId}" />
            <TextBlock Margin="0,10,0,0"
                       Foreground="{StaticResource StackrootAccentTextBrush}"
                       Text="{Binding SelectedPhpSummary}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <TextBlock Grid.Row="2"
                   Margin="0,10,0,0"
                   Foreground="{StaticResource StackrootDangerTextBrush}"
                   Text="{Binding ValidationMessage}"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="3"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button MinWidth="88"
                    Margin="0,0,8,0"
                    Content="{DynamicResource Loc.Common.Cancel}"
                    Command="{Binding CancelCommand}" />
            <Button MinWidth="108"
                    Style="{StaticResource StackrootPrimaryButtonStyle}"
                    Content="{DynamicResource Loc.Common.Install}"
                    Command="{Binding ConfirmCommand}" />
        </StackPanel>
    </Grid>
</Window>
