<Window x:Class="Stackroot.App.Views.EditSiteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Stackroot.App.Helpers"
        xmlns:controls="clr-namespace:Stackroot.App.Views.Controls"
        xmlns:vm="clr-namespace:Stackroot.App.ViewModels"
        Title="Edit web domain"
        Width="580"
        MinWidth="540"
        SizeToContent="Height"
        MaxHeight="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="DevProxyExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="{StaticResource StackrootCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StackrootBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource StackrootTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <DockPanel LastChildFill="True">
                                <ToggleButton DockPanel.Dock="Top"
                                              MinHeight="44"
                                              Padding="0"
                                              HorizontalContentAlignment="Stretch"
                                              VerticalContentAlignment="Stretch"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Focusable="False"
                                              IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Grid Background="Transparent" MinHeight="44">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontFamily="{StaticResource StackrootIconFont}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                                           Text="&#xE70D;"
                                                           RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform Angle="0" />
                                                    </TextBlock.RenderTransform>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                                    <Setter Property="RenderTransform">
                                                                        <Setter.Value>
                                                                            <RotateTransform Angle="90" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <ContentPresenter Grid.Column="1"
                                                                  Margin="0,0,12,0"
                                                                  VerticalAlignment="Center"
                                                                  Content="{Binding Header, RelativeSource={RelativeSource AncestorType=Expander}}"
                                                                  RecognizesAccessKey="True" />
                                            </Grid>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpandSite"
                                                  Margin="12,0,12,12"
                                                  ContentSource="Content"
                                                  Visibility="Collapsed" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="Edit web domain" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Update template, PHP backend, HTTPS behavior, and dev proxies."
                       TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      Margin="0,16,0,0"
                      MaxHeight="620"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="10"
                        Background="#1AE9BD5B"
                        BorderBrush="#52E9BD5B"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Foreground="{StaticResource StackrootWarnBrush}"
                               Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap" />
                </Border>

                <TextBlock Margin="0,12,0,6"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Domain" />
                <TextBlock FontFamily="Consolas" Text="{Binding Domain}" />
                <TextBlock Margin="0,2,0,0"
                           FontSize="12"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Domain cannot be changed — delete and re-add to rename." />

                <TextBlock Margin="0,12,0,6"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Domain aliases (optional)" />
                <TextBox MinHeight="72"
                         Padding="10,6"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         Text="{Binding DomainAliasesText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="One alias per line (e.g. sameapp.test or *.app.test). Wildcard aliases work in nginx; literal names are added to hosts and HTTPS."
                           TextWrapping="Wrap" />

                <TextBlock Margin="0,12,0,6"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Folder" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Padding="10,6"
                             FontFamily="Consolas"
                             Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Margin="8,0,0,0"
                            Padding="12,6"
                            Command="{Binding BrowseFolderCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="16"
                                   Height="16"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center"
                                   Source="{x:Static helpers:StackrootImages.FolderIcon}"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock VerticalAlignment="Center"
                                       Text="Browse…" />
                        </StackPanel>
                    </Button>
                </Grid>
                <TextBlock Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="nginx document root follows this folder and the template doc root."
                           TextWrapping="Wrap" />

                <TextBlock Margin="0,16,0,8"
                           FontWeight="SemiBold"
                           Text="Template" />
                <ItemsControl ItemsSource="{Binding TemplateCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,8,8"
                                    Padding="10"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding SelectCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource StackrootButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource StackrootAccentBrush}" />
                                                <Setter Property="Background" Value="#223047" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource StackrootTextMutedBrush}"
                                               Text="{Binding DocumentRoot, StringFormat=doc root: {0}}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="0,8,0,6"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Site name" />
                <TextBox Padding="10,6"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,12,0,6"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Backend (PHP)" />
                <ComboBox Padding="8,4"
                          ItemsSource="{Binding PhpVersions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedPhpVersionId}"
                          IsEnabled="{Binding PhpSelectorEnabled}" />

                <TextBlock Margin="0,12,0,6"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Document root" />
                <TextBlock FontFamily="Consolas"
                           Text="{Binding DocumentRootLabel}" />

                <CheckBox Margin="0,14,0,0"
                          Content="Enabled (nginx vhost + hosts entry)"
                          IsChecked="{Binding Enabled}" />
                <CheckBox Margin="0,10,0,0"
                          Content="Force HTTPS (redirect HTTP → HTTPS)"
                          IsChecked="{Binding ForceHttps}" />
                <TextBlock Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="When off, the site is served over HTTP only — avoids browser auto-upgrade to HTTPS."
                           TextWrapping="Wrap" />

                <DockPanel Margin="0,18,0,8" LastChildFill="False">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Dev proxies" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                   Text="{Binding EnabledProxyCount, StringFormat={}{0} active}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Margin="0,0,8,0"
                                Padding="10,4"
                                Content="Add regex proxy"
                                Command="{Binding AddRegexProxyCommand}" />
                        <Button Padding="10,4"
                                Content="Add proxy"
                                Command="{Binding AddProxyCommand}" />
                    </StackPanel>
                </DockPanel>

                <TextBlock Margin="0,0,0,8"
                           FontSize="12"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="No proxies yet — add one to route e.g. /vite/ to a local dev server."
                           Visibility="{Binding ShowEmptyProxies, Converter={StaticResource BoolToVis}}" />

                <ItemsControl ItemsSource="{Binding DevProxies}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="0,0,0,10"
                                      Style="{StaticResource DevProxyExpanderStyle}"
                                      IsExpanded="{Binding IsExpanded}">
                                <Expander.Header>
                                    <DockPanel LastChildFill="False"
                                               VerticalAlignment="Center">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                                   Text="{Binding StatusHint}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding HeaderText}" />
                                    </DockPanel>
                                </Expander.Header>
                                <StackPanel Margin="12,0,12,12">
                                    <DockPanel Margin="0,0,0,8" LastChildFill="False">
                                        <CheckBox DockPanel.Dock="Left"
                                                  Content="Enabled"
                                                  IsChecked="{Binding Enabled}" />
                                        <controls:OverflowMenuButton DockPanel.Dock="Right"
                                                                     DangerLabel="Remove"
                                                                     DangerCommand="{Binding RemoveCommand}"
                                                                     ButtonWidth="30"
                                                                     ButtonHeight="28" />
                                    </DockPanel>
                                    <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}" Text="Name" />
                                    <TextBox Margin="0,4,0,0"
                                             Padding="8,4"
                                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource StackrootTextMutedBrush}"
                                               Text="Match type" />
                                    <ComboBox Margin="0,4,0,0"
                                              Padding="8,4"
                                              ItemsSource="{x:Static vm:DevProxyRowViewModel.LocationKindOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedItem="{Binding SelectedLocationKindOption}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource StackrootTextMutedBrush}"
                                               Text="Location pattern" />
                                    <TextBox Margin="0,4,0,0"
                                             Padding="8,4"
                                             AcceptsReturn="False"
                                             Text="{Binding LocationPath, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource StackrootTextMutedBrush}"
                                               Text="{Binding LocationPatternHint}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource StackrootTextMutedBrush}"
                                               Text="Paste only the pattern (e.g. ^/path$), not the full nginx location line."
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource StackrootTextMutedBrush}"
                                               FontFamily="Consolas"
                                               Text="{Binding NginxLocationPreview}"
                                               TextWrapping="Wrap" />
                                    <CheckBox Margin="0,8,0,0"
                                              Content="WebSocket support"
                                              IsChecked="{Binding Websocket}" />
                                    <DockPanel Margin="0,12,0,0" LastChildFill="False">
                                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Proxy directives" />
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Margin="0,0,8,0"
                                                    Padding="8,2"
                                                    Content="Reset defaults"
                                                    Command="{Binding ResetDirectivesCommand}" />
                                            <Button Padding="8,2"
                                                    Content="Add directive"
                                                    Command="{Binding AddDirectiveCommand}" />
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource StackrootTextMutedBrush}"
                                               Text="Set proxy_pass to the upstream URL. Add other nginx directives as needed; they are saved with the site."
                                               TextWrapping="Wrap" />
                                    <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding Directives}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,0,0,6" LastChildFill="True">
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="8,0,0,0"
                                                            Padding="8,2"
                                                            Content="Remove"
                                                            Command="{Binding RemoveCommand}" />
                                                    <TextBox Margin="0,0,6,0"
                                                             DockPanel.Dock="Left"
                                                             Width="180"
                                                             Padding="6,3"
                                                             FontFamily="Consolas"
                                                             Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBox Padding="6,3"
                                                             FontFamily="Consolas"
                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,18,0,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Width="88"
                        Margin="0,0,8,0"
                        Content="Cancel"
                        Command="{Binding CloseCommand}" />
                <Button Width="88"
                        Content="Save"
                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                        Command="{Binding SaveCommand}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
