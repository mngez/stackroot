<Window x:Class="Stackroot.App.Views.DatabasesSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Stackroot.App.Views.Controls"
        Title="Database settings"
        Width="460"
        MinWidth="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="Database settings" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Credentials from settings are applied to MySQL/MariaDB automatically. Passwords are shown in plain text for local development."
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock FontWeight="SemiBold" Text="MySQL credentials" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Username" />
            <TextBox Margin="0,6,0,0"
                     Text="{Binding MysqlUsername, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Margin="0,12,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Password" />
            <TextBox Margin="0,6,0,0"
                     Text="{Binding MysqlPassword, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Margin="0,18,0,0"
                       FontWeight="SemiBold"
                       Text="MariaDB credentials" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Username" />
            <TextBox Margin="0,6,0,0"
                     Text="{Binding MariadbUsername, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Margin="0,12,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Password" />
            <TextBox Margin="0,6,0,0"
                     Text="{Binding MariadbPassword, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       MinHeight="16"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
            <DockPanel Margin="0,12,0,0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="88"
                            Margin="0,0,8,0"
                            Content="Close"
                            Command="{Binding CloseCommand}" />
                    <Button Width="88"
                            Content="Save"
                            Style="{StaticResource StackrootPrimaryButtonStyle}"
                            Command="{Binding SaveCommand}" />
                </StackPanel>
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
