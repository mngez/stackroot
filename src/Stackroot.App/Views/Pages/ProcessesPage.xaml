<UserControl x:Class="Stackroot.App.Views.Pages.ProcessesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Stackroot.App.Views.Controls">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <StackPanel>
                <TextBlock Text="Processes"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Unified supervisor for app-wide and site-linked background commands" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right"
                        Style="{StaticResource StackrootPageActionsStyle}">
                <Button MinWidth="100"
                        Margin="0,0,10,0"
                        Content="+ Add"
                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                        Command="{Binding AddCommand}" />
                <Button MinWidth="100"
                        Content="Refresh"
                        Command="{Binding RefreshCommand}" />
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Row="1"
                    Margin="0,14,0,0"
                    Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Margin="0,0,8,0"
                       Text="Site filter:" />
            <ComboBox Width="280"
                      DisplayMemberPath="Label"
                      SelectedValuePath="Id"
                      SelectedValue="{Binding SiteFilter}"
                      ItemsSource="{Binding SiteFilterOptions}" />
            <Button Content="Start all enabled"
                    Margin="12,0,0,0"
                    Padding="12,4"
                    Style="{StaticResource StackrootPrimaryButtonStyle}"
                    Command="{Binding StartAllCommand}" />
            <Button Content="Stop all"
                    Margin="8,0,0,0"
                    Padding="12,4"
                    Style="{StaticResource StackrootStopButtonStyle}"
                    Command="{Binding StopAllCommand}" />
        </StackPanel>

        <TextBlock Grid.Row="2"
                   Margin="0,10,0,0"
                   Foreground="{StaticResource StackrootDangerBrush}"
                   Text="{Binding ErrorMessage}"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <StackPanel Grid.Row="3" Margin="0,12,0,24">
            <Border Padding="14"
                    Background="{StaticResource StackrootCardBrush}"
                    BorderBrush="{StaticResource StackrootBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="No processes match the current filters."
                               Foreground="{StaticResource StackrootTextMutedBrush}" />
                    <Button Margin="0,10,0,0"
                            Width="140"
                            HorizontalAlignment="Left"
                            Content="+ Add process"
                            Style="{StaticResource StackrootPrimaryButtonStyle}"
                            Command="{Binding AddCommand}" />
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding Processes}"
                          Visibility="{Binding HasProcesses, Converter={StaticResource BoolToVis}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8"
                                Padding="10,8"
                                Background="#121A26"
                                BorderBrush="{Binding RowBorder}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" MinWidth="120" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Width="36"
                                        Height="36"
                                        Margin="0,0,8,0"
                                        Padding="0"
                                        Style="{StaticResource StackrootIconButtonStyle}"
                                        ToolTip="Pin to featured"
                                        Command="{Binding DataContext.ToggleFeaturedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                               FontSize="15"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding PinColor}"
                                               Text="{Binding PinGlyph}" />
                                </Button>

                                <Ellipse Grid.Column="1"
                                         Width="10"
                                         Height="10"
                                         Margin="0,0,10,0"
                                         VerticalAlignment="Center"
                                         Fill="{Binding IndicatorBrush}" />

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Name}" />
                                    <TextBlock Margin="0,2,0,0"
                                               Foreground="{StaticResource StackrootTextMutedBrush}"
                                               FontSize="12"
                                               Text="{Binding CommandLine}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding CommandLine}" />
                                    <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                        <Border Margin="0,0,6,0"
                                                Padding="6,2"
                                                Background="#223047"
                                                CornerRadius="4">
                                            <TextBlock FontSize="11"
                                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                                       Text="{Binding RuntimeLabel}" />
                                        </Border>
                                        <Border Padding="6,2"
                                                Background="#223047"
                                                CornerRadius="4">
                                            <TextBlock FontSize="11"
                                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                                       Text="{Binding SiteLabel}" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="3"
                                        Margin="12,0,12,0"
                                        Style="{StaticResource StackrootLiveBadgeStyle}"
                                        ToolTip="{Binding UptimeToolTip}"
                                        Visibility="{Binding IsLive, Converter={StaticResource BoolToVis}}">
                                    <TextBlock FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource StackrootAccentTextBrush}"
                                               Text="LIVE" />
                                </Border>

                                <StackPanel Grid.Column="4"
                                            MinWidth="88"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{Binding StatusBrush}"
                                               Text="{Binding StatusText}" />
                                    <ProgressBar Margin="0,5,0,0"
                                                 Height="3"
                                                 IsIndeterminate="True"
                                                 Visibility="{Binding ShowBusyIndicator, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>

                                <StackPanel Grid.Column="5"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                    <Button Content="Start"
                                            Padding="8,3"
                                            Margin="0,0,4,0"
                                            FontSize="12"
                                            Style="{StaticResource StackrootPrimaryButtonStyle}"
                                            Command="{Binding DataContext.StartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}"
                                            IsEnabled="{Binding CanStart}" />
                                    <Button Content="Stop"
                                            Padding="8,3"
                                            Margin="0,0,4,0"
                                            FontSize="12"
                                            Style="{StaticResource StackrootStopButtonStyle}"
                                            Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}" />
                                    <Button Content="Restart"
                                            Padding="8,3"
                                            Margin="0,0,4,0"
                                            FontSize="12"
                                            Command="{Binding DataContext.RestartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}"
                                            Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Log"
                                            Padding="8,3"
                                            Margin="0,0,4,0"
                                            FontSize="12"
                                            Command="{Binding DataContext.ViewLogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Edit"
                                            Padding="8,3"
                                            Margin="0,0,4,0"
                                            FontSize="12"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                    <controls:OverflowMenuButton Margin="0,0,0,0"
                                                                 DangerLabel="Remove"
                                                                 DangerCommand="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 DangerCommandParameter="{Binding}"
                                                                 ButtonWidth="30"
                                                                 ButtonHeight="28" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
