<UserControl x:Class="Stackroot.App.Views.Pages.DownloadsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Stackroot.App.Helpers">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Downloads"
                   FontSize="28"
                   FontWeight="SemiBold" />

        <TextBlock Grid.Row="1"
                   Margin="0,8,0,0"
                   Foreground="{StaticResource StackrootTextMutedBrush}"
                   Text="{Binding CachePath, StringFormat=Cache folder: {0}}"
                   TextWrapping="Wrap" />

        <DockPanel Grid.Row="2"
                   Margin="0,14,0,12"
                   LastChildFill="False">
            <TextBlock VerticalAlignment="Center"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{Binding TotalText}" />
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button Width="112"
                        Margin="0,0,8,0"
                        Command="{Binding OpenFolderCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="16"
                               Height="16"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               Source="{x:Static helpers:StackrootImages.FolderIcon}"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock VerticalAlignment="Center"
                                   Text="Open folder" />
                    </StackPanel>
                </Button>
                <Button Width="96"
                        Content="Refresh"
                        Command="{Binding RefreshCommand}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="3"
                Padding="1"
                Background="{StaticResource StackrootCardBrush}"
                BorderBrush="{StaticResource StackrootBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <DataGrid AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      Background="Transparent"
                      AlternationCount="2"
                      AlternatingRowBackground="#131D2A"
                      RowBackground="Transparent"
                      ItemsSource="{Binding Items}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="MinHeight" Value="40" />
                        <Setter Property="BorderBrush" Value="#1E324A" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A2A3D" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#223047" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Package" Binding="{Binding PackageId}" Width="160" />
                    <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="2*" />
                    <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="110" />
                    <DataGridTextColumn Header="Downloaded" Binding="{Binding DownloadedAt}" Width="160" />
                    <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="3*" />
                    <DataGridTemplateColumn Header="Action" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Remove"
                                        Padding="6,2"
                                        MinHeight="22"
                                        VerticalAlignment="Center"
                                        Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="4"
                   Margin="0,8,0,24"
                   Foreground="{StaticResource StackrootTextMutedBrush}"
                   Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>
