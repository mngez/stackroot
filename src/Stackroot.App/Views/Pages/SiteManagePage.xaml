<UserControl x:Class="Stackroot.App.Views.Pages.SiteManagePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Stackroot.App.Helpers"
             xmlns:controls="clr-namespace:Stackroot.App.Views.Controls">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="SiteManagePinButtonStyle" TargetType="Button" BasedOn="{StaticResource StackrootIconButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource StackrootTextMutedBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <StackPanel>
                <TextBlock Text="Site dashboard"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                    <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{Binding Site.Domain}" />
                    <Border Margin="10,0,0,0"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            Background="#1A4CAE8C"
                            CornerRadius="4"
                            Visibility="{Binding SiteEnabled, Converter={StaticResource BoolToVis}}">
                        <TextBlock FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource StackrootAccentTextBrush}"
                                   Text="Live" />
                    </Border>
                    <Border Margin="8,0,0,0"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            Background="#332E5BFF"
                            CornerRadius="4"
                            Visibility="{Binding ShowHttpsBadge, Converter={StaticResource BoolToVis}}">
                        <TextBlock FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#9BB8F0"
                                   Text="HTTPS" />
                    </Border>
                </StackPanel>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right"
                        Style="{StaticResource StackrootPageActionsStyle}">
                <Button Margin="0,0,10,0"
                        Style="{StaticResource SiteManagePinButtonStyle}"
                        ToolTip="{Binding FeaturedPinToolTip}"
                        Command="{Binding ToggleFeaturedCommand}">
                    <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE734;" />
                                <Setter Property="Foreground" Value="{StaticResource StackrootTextMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFeatured}" Value="True">
                                        <Setter Property="Text" Value="&#xE735;" />
                                        <Setter Property="Foreground" Value="{StaticResource StackrootWarnBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
                <Button MinWidth="72"
                        Margin="0,0,10,0"
                        Content="Edit"
                        Command="{Binding EditSiteCommand}" />
                <Button MinWidth="88"
                        Margin="0,0,10,0"
                        Content="{Binding ToggleEnabledButtonLabel}"
                        Command="{Binding ToggleEnabledCommand}"
                        IsEnabled="{Binding IsNotTogglingEnabled}"
                        Visibility="{Binding SiteEnabled, Converter={StaticResource BoolToVis}}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource StackrootStopButtonStyle}">
                            <Setter Property="MinWidth" Value="88" />
                        </Style>
                    </Button.Style>
                </Button>
                <Button MinWidth="88"
                        Margin="0,0,10,0"
                        Content="{Binding ToggleEnabledButtonLabel}"
                        Command="{Binding ToggleEnabledCommand}"
                        IsEnabled="{Binding IsNotTogglingEnabled}"
                        Visibility="{Binding SiteDisabled, Converter={StaticResource BoolToVis}}" />
                <Button MinWidth="100"
                        Margin="0,0,10,0"
                        Content="Terminal"
                        Command="{Binding OpenTerminalCommand}" />
                <Button MinWidth="100"
                        Margin="0,0,10,0"
                        Content="Refresh"
                        Command="{Binding RefreshCommand}" />
                <Button MinWidth="100"
                        Margin="0,0,10,0"
                        Content="SSL paths"
                        ToolTip="Local dev.crt and dev.key paths"
                        Command="{Binding OpenSslPathsCommand}"
                        Visibility="{Binding HasDevSslPaths, Converter={StaticResource BoolToVis}}" />
                <Button MinWidth="100"
                        Content="← Sites"
                        Command="{Binding BackCommand}" />
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Row="1"
                    Margin="0,14,0,24">

                <!-- Info cards -->
                <UniformGrid Columns="4">
                    <Border Margin="0,0,8,0"
                            Padding="14"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    ToolTip="Open site in browser"
                                    Style="{StaticResource StackrootIconButtonStyle}"
                                    Command="{Binding OpenSiteCommand}">
                                <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                           FontSize="14"
                                           Text="&#xE71B;" />
                            </Button>
                            <StackPanel>
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                           Text="TEMPLATE" />
                                <TextBlock Margin="0,6,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="{Binding TemplateLabel}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Border Margin="4,0"
                            Padding="14"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                       Text="PHP" />
                            <ComboBox Margin="0,6,0,0"
                                      Padding="6,4"
                                      ItemsSource="{Binding PhpVersions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SelectedPhpVersionId}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="4,0"
                            Padding="14"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                       Text="Node.js" />
                            <ComboBox Margin="0,6,0,0"
                                      Padding="6,4"
                                      ItemsSource="{Binding NodeVersions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SelectedNodeVersionId}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="8,0,0,0"
                            Padding="14"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    ToolTip="Open site folder"
                                    Style="{StaticResource StackrootIconButtonStyle}"
                                    Command="{Binding OpenFolderCommand}">
                                <Image Width="16"
                                       Height="16"
                                       Source="{x:Static helpers:StackrootImages.FolderIcon}"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Button>
                            <StackPanel>
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                           Text="PATH" />
                                <TextBlock Margin="0,6,0,0"
                                           FontSize="13"
                                           Text="{Binding Site.Path}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Site.Path}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </UniformGrid>

                <!-- Post-install WordPress card + thumbnail side by side -->
                <Border Margin="0,14,0,0"
                        Padding="14"
                        Background="{StaticResource StackrootCardBrush}"
                        BorderBrush="{StaticResource StackrootBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="{Binding ShowWordPressPostInstallCard, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: WordPress info -->
                        <StackPanel Grid.Column="0">
                            <DockPanel LastChildFill="False">
                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource StackrootAccentTextBrush}"
                                               Text="{Binding PostInstallWpLabel, Mode=OneWay}" />
                                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource StackrootTextMutedBrush}"
                                               Text="Installed and ready" />
                                </StackPanel>
                            </DockPanel>

                            <!-- Credentials row -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                           Foreground="{StaticResource StackrootTextMutedBrush}" Text="Username" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Margin="8,0" VerticalAlignment="Center"
                                           FontFamily="Consolas" Text="{Binding PostInstallAdminUser}" />
                                <Button Grid.Row="0" Grid.Column="2" Width="60" Height="28" Padding="8,2"
                                        Content="Copy" Style="{StaticResource StackrootInlineButtonStyle}"
                                        Command="{Binding CopyPasswordCommand}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0" VerticalAlignment="Center"
                                           Foreground="{StaticResource StackrootTextMutedBrush}" Text="Password" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="8,6,0,0" VerticalAlignment="Center"
                                           FontFamily="Consolas" Text="{Binding PostInstallPasswordDisplay}" />
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,6,0,0" Orientation="Horizontal">
                                    <Button Width="28" Height="28" Padding="4"
                                            Content="👁" ToolTip="Show/hide password"
                                            Style="{StaticResource StackrootInlineButtonStyle}"
                                            Command="{Binding TogglePasswordCommand}" />
                                    <Button Width="28" Height="28" Padding="4" Margin="4,0,0,0"
                                            Content="📋" ToolTip="Copy password"
                                            Style="{StaticResource StackrootInlineButtonStyle}"
                                            Command="{Binding CopyPasswordCommand}" />
                                    <Button Width="28" Height="28" Padding="4" Margin="4,0,0,0"
                                            Content="🔄" ToolTip="Change password"
                                            Style="{StaticResource StackrootInlineButtonStyle}"
                                            Command="{Binding ChangePasswordCommand}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button MinWidth="110" Padding="14,8" Content="Open site"
                                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                                        Command="{Binding OpenSiteCommand}" />
                                <Button MinWidth="100" Margin="8,0,0,0" Padding="14,8" Content="Open admin"
                                        Command="{Binding OpenPostInstallAdminCommand}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Right: Square thumbnail -->
                        <Border Grid.Column="1"
                                Margin="20,0,0,0"
                                Width="200" Height="200"
                                Background="#0A0F1A"
                                BorderBrush="{StaticResource StackrootBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True"
                                Visibility="{Binding ShowThumbnailColumn, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <!-- Spinner while capturing -->
                                <Border Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVis}}"
                                        Background="#990A0F1A">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center" />
                                        <TextBlock Text="Capturing…" FontSize="12"
                                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                                   Margin="0,6,0,0" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <!-- Thumbnail image -->
                                <Image Source="{Binding ThumbnailImage}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}" />
                                <!-- Refresh button -->
                                <Button HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,4,4"
                                        Width="28" Height="28"
                                        Padding="2"
                                        ToolTip="Refresh screenshot"
                                        Style="{StaticResource StackrootIconButtonStyle}"
                                        Command="{Binding CaptureThumbnailCommand}"
                                        Visibility="{Binding ShowRefreshButton, Converter={StaticResource BoolToVis}}">
                                    <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                               FontSize="12"
                                               Text="&#xE72C;" />
                                </Button>
                                <!-- Capture button when no image -->
                                <Button VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        MinWidth="100"
                                        Padding="14,8"
                                        Content="Capture"
                                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                                        Command="{Binding CaptureThumbnailCommand}"
                                        Visibility="{Binding ShowCaptureButton, Converter={StaticResource BoolToVis}}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Post-install Laravel card + thumbnail -->
                <Border Margin="0,14,0,0"
                        Padding="14"
                        Background="{StaticResource StackrootCardBrush}"
                        BorderBrush="{StaticResource StackrootBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="{Binding ShowLaravelPostInstallCard, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <!-- Custom command status bars -->
                            <ItemsControl ItemsSource="{Binding ActiveCommandStatuses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,4" Padding="10,8"
                                                Background="#121A26"
                                                BorderBrush="{StaticResource StackrootBorderBrush}"
                                                BorderThickness="1" CornerRadius="8">
                                            <DockPanel LastChildFill="True">
                                                <Button DockPanel.Dock="Right"
                                                        Width="28"
                                                        Height="28"
                                                        Padding="0"
                                                        Margin="8,0,0,0"
                                                        ToolTip="Dismiss"
                                                        Style="{StaticResource StackrootIconButtonStyle}"
                                                        Command="{Binding DataContext.DismissCustomStatusCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding ShowDismissStatus, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                                               FontSize="12"
                                                               Text="&#xE711;" />
                                                </Button>
                                                <Button DockPanel.Dock="Right"
                                                        Margin="8,0,0,0"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        Content="Cancel"
                                                        Command="{Binding CancelCommand}"
                                                        Visibility="{Binding ShowCancelStatus, Converter={StaticResource BoolToVis}}" />
                                                <Button DockPanel.Dock="Right"
                                                        Margin="8,0,0,0"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        Content="View log"
                                                        ToolTip="{x:Static helpers:StackrootLogViewer.CtrlClickEditorToolTip}"
                                                        PreviewMouseLeftButtonDown="OnCustomCommandViewLogClick"
                                                        Visibility="{Binding ShowViewLogButton, Converter={StaticResource BoolToVis}}" />
                                                <TextBlock VerticalAlignment="Center"
                                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                                           FontSize="12"
                                                           Text="{Binding Status}" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource StackrootAccentTextBrush}">
                                <Run Text="🔺 Laravel" />
                                <Run Text="{Binding PostInstallLaravelVersion, Mode=OneWay, StringFormat=' {}', TargetNullValue=''}" />
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource StackrootTextMutedBrush}"
                                       Text="Installed and ready" />

                            <!-- Open site + custom commands + add -->
                            <WrapPanel Margin="0,8,0,0">
                                <Button Padding="10,6"
                                        Content="Open site"
                                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                                        Command="{Binding OpenSiteCommand}" />
                                <ItemsControl ItemsSource="{Binding CustomCommandItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="4,0,0,0"
                                                    Padding="10,6"
                                                    ToolTip="{Binding Command}"
                                                    Command="{Binding RunCommand}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource StackrootPrimaryButtonStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCustomChrome}" Value="True">
                                                                <Setter Property="Background" Value="{Binding CustomBackgroundBrush}" />
                                                                <Setter Property="Foreground" Value="{Binding CustomForegroundBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Width="16"
                                                           Height="16"
                                                           Margin="0,0,6,0"
                                                           Source="{Binding IconSource}"
                                                           Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding DisplayLabel}" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Margin="4,0,0,0"
                                        Width="34"
                                        Height="34"
                                        Padding="0"
                                        ToolTip="Manage custom commands"
                                        Style="{StaticResource StackrootIconButtonStyle}"
                                        Command="{Binding ManageCustomCommandsCommand}">
                                    <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                               FontSize="14"
                                               Text="&#xE8FD;" />
                                </Button>
                            </WrapPanel>
                        </StackPanel>

                        <!-- Right: Square thumbnail -->
                        <Border Grid.Column="1"
                                Margin="20,0,0,0"
                                Width="200" Height="200"
                                Background="#0A0F1A"
                                BorderBrush="{StaticResource StackrootBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True"
                                Visibility="{Binding ShowThumbnailColumn, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Border Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVis}}"
                                        Background="#990A0F1A">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center" />
                                        <TextBlock Text="Capturing…" FontSize="12"
                                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                                   Margin="0,6,0,0" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Image Source="{Binding ThumbnailImage}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}" />
                                <Button HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,4,4"
                                        Width="28" Height="28"
                                        Padding="2"
                                        ToolTip="Refresh screenshot"
                                        Style="{StaticResource StackrootIconButtonStyle}"
                                        Command="{Binding CaptureThumbnailCommand}"
                                        Visibility="{Binding ShowRefreshButton, Converter={StaticResource BoolToVis}}">
                                    <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                               FontSize="12"
                                               Text="&#xE72C;" />
                                </Button>
                                <Button VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        MinWidth="100"
                                        Padding="14,8"
                                        Content="Capture"
                                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                                        Command="{Binding CaptureThumbnailCommand}"
                                        Visibility="{Binding ShowCaptureButton, Converter={StaticResource BoolToVis}}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Installer -->
                <Border Margin="0,14,0,0"
                        Padding="14"
                        Background="{StaticResource StackrootCardBrush}"
                        BorderBrush="{StaticResource StackrootBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="{Binding ShowInstallerButton, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Text="{Binding InstallerButtonLabel}" />
                            <Button DockPanel.Dock="Right"
                                    MinWidth="120"
                                    Padding="14,8"
                                    Content="Install"
                                    Style="{StaticResource StackrootPrimaryButtonStyle}"
                                    Command="{Binding InstallSiteCommand}" />
                        </DockPanel>
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                   Text="{Binding InstallStatus}"
                                   Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Border>

                <!-- Quick actions -->
                <Border Margin="0,14,0,0"
                        Padding="14"
                        Background="{StaticResource StackrootCardBrush}"
                        BorderBrush="{StaticResource StackrootBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Quick actions" />
                        </DockPanel>

                        <Border Margin="0,10,0,0"
                                Padding="10,8"
                                Background="#121A26"
                                BorderBrush="{StaticResource StackrootBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Visibility="{Binding ShowCommandStatus, Converter={StaticResource BoolToVis}}">
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right"
                                        Width="28"
                                        Height="28"
                                        Padding="0"
                                        Margin="8,0,0,0"
                                        ToolTip="Dismiss"
                                        Style="{StaticResource StackrootIconButtonStyle}"
                                        Command="{Binding DismissCommandStatusCommand}"
                                        Visibility="{Binding ShowDismissCommandStatus, Converter={StaticResource BoolToVis}}">
                                    <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                               FontSize="12"
                                               Text="&#xE711;" />
                                </Button>
                                <Button DockPanel.Dock="Right"
                                        Margin="8,0,0,0"
                                        Padding="8,4"
                                        FontSize="12"
                                        Content="Cancel"
                                        Command="{Binding CancelCommandStatusCommand}"
                                        Visibility="{Binding ShowCancelCommandStatus, Converter={StaticResource BoolToVis}}" />
                                <Button DockPanel.Dock="Right"
                                        Margin="8,0,0,0"
                                        Padding="8,4"
                                        FontSize="12"
                                        Content="View log"
                                        ToolTip="{x:Static helpers:StackrootLogViewer.CtrlClickEditorToolTip}"
                                        PreviewMouseLeftButtonDown="OnQuickActionViewLogClick"
                                        Visibility="{Binding ShowCommandLogButton, Converter={StaticResource BoolToVis}}" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                           FontSize="12"
                                           Text="{Binding CommandStatusMessage}" />
                            </DockPanel>
                        </Border>

                        <ItemsControl Margin="0,10,0,0"
                                      ItemsSource="{Binding QuickActionGroups}"
                                      Visibility="{Binding HasQuickActions, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Margin="0,0,0,4"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                                   Text="{Binding Title}" />
                                        <ItemsControl ItemsSource="{Binding Actions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button MinHeight="32"
                                                            Margin="0,0,6,6"
                                                            Padding="10,6"
                                                            ToolTip="{Binding Label}"
                                                            Command="{Binding Command}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                                <Setter Property="Background" Value="#121A26" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource StackrootBorderBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDangerous}" Value="True">
                                                                        <Setter Property="Background" Value="#33E88A92" />
                                                                        <Setter Property="BorderBrush" Value="#66E88A92" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Grid Width="16"
                                                                  Height="16"
                                                                  Margin="0,0,7,0"
                                                                  VerticalAlignment="Center">
                                                                <Image Width="16"
                                                                       Height="16"
                                                                       Source="{Binding IconSource}"
                                                                       Stretch="Uniform"
                                                                       Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                                                                <Ellipse Width="7"
                                                                         Height="7"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"
                                                                         Fill="{Binding AccentBrush}">
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasIcon}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>
                                                            </Grid>
                                                            <TextBlock Margin="0,0,8,0"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                                                       Text="{Binding RuntimeBadge}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasIcon}" Value="False">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock VerticalAlignment="Center"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding ShortLabel}" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Databases -->
                <Border Margin="0,14,0,0"
                        Padding="14"
                        Background="{StaticResource StackrootCardBrush}"
                        BorderBrush="{StaticResource StackrootBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Databases" />
                            <Button DockPanel.Dock="Right"
                                    Padding="8,4"
                                    FontSize="12"
                                    Content="+ Create"
                                    Style="{StaticResource StackrootPrimaryButtonStyle}"
                                    Command="{Binding CreateDatabaseCommand}" />
                        </DockPanel>

                        <Border Margin="0,10,0,0"
                                Padding="10,8"
                                Background="#121A26"
                                BorderBrush="{StaticResource StackrootBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Visibility="{Binding ShowDatabaseStatus, Converter={StaticResource BoolToVis}}">
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right"
                                        Width="28"
                                        Height="28"
                                        Padding="0"
                                        Margin="8,0,0,0"
                                        ToolTip="Dismiss"
                                        Style="{StaticResource StackrootIconButtonStyle}"
                                        Command="{Binding DismissDatabaseStatusCommand}">
                                    <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                               FontSize="12"
                                               Text="&#xE711;" />
                                </Button>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                           FontSize="12"
                                           Text="{Binding DatabaseStatusMessage}" />
                            </DockPanel>
                        </Border>

                        <TextBlock Margin="0,10,0,0"
                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                   Text="No databases linked to this site yet."
                                   Visibility="{Binding ShowNoLinkedDatabases, Converter={StaticResource BoolToVis}}" />

                        <ItemsControl Margin="0,10,0,0"
                                      ItemsSource="{Binding LinkedDatabases}"
                                      Visibility="{Binding HasLinkedDatabases, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="12,10"
                                            Background="#121A26"
                                            BorderBrush="{StaticResource StackrootBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Right"
                                                        Orientation="Horizontal">
                                                <Button Margin="0,0,6,0"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        Content="Copy .env"
                                                        Command="{Binding CopyEnvCommand}" />
                                                <Button Padding="8,4"
                                                        FontSize="12"
                                                        Content="View .env"
                                                        Command="{Binding ViewEnvCommand}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding Name}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                                           FontSize="12"
                                                           Text="{Binding EngineLabel}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Processes -->
                <Border Margin="0,14,0,0"
                        Padding="14"
                        Background="{StaticResource StackrootCardBrush}"
                        BorderBrush="{StaticResource StackrootBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Processes" />
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal">
                                <Button Margin="0,0,6,0"
                                        Style="{StaticResource StackrootInlinePrimaryButtonStyle}"
                                        Content="Start all"
                                        Command="{Binding StartAllProcessesCommand}" />
                                <Button Margin="0,0,6,0"
                                        Style="{StaticResource StackrootInlineStopButtonStyle}"
                                        Content="Stop all"
                                        Command="{Binding StopAllProcessesCommand}" />
                                <Button Padding="8,4"
                                        FontSize="12"
                                        Content="+ Custom"
                                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                                        Command="{Binding AddProcessCommand}" />
                            </StackPanel>
                        </DockPanel>

                        <Border Margin="0,10,0,0"
                                Padding="10,8"
                                Background="#121A26"
                                BorderBrush="{StaticResource StackrootBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Visibility="{Binding ShowProcessStatus, Converter={StaticResource BoolToVis}}">
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right"
                                        Width="28"
                                        Height="28"
                                        Padding="0"
                                        Margin="8,0,0,0"
                                        ToolTip="Dismiss"
                                        Style="{StaticResource StackrootIconButtonStyle}"
                                        Command="{Binding DismissProcessStatusCommand}">
                                    <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                               FontSize="12"
                                               Text="&#xE711;" />
                                </Button>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Text="{Binding ProcessStatusMessage}" />
                            </DockPanel>
                        </Border>

                        <TextBlock Margin="0,10,0,0"
                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                   FontSize="12"
                                   Text="Quick-add presets:"
                                   Visibility="{Binding HasProcessPresets, Converter={StaticResource BoolToVis}}" />

                        <ItemsControl Margin="0,8,0,0"
                                      ItemsSource="{Binding ProcessPresets}"
                                      Visibility="{Binding HasProcessPresets, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,8,8"
                                            Padding="8,4"
                                            FontSize="12"
                                            ToolTip="{Binding Description}"
                                            Content="{Binding Name}"
                                            Command="{Binding AddCommand}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                   Text="No processes linked to this site yet."
                                   Visibility="{Binding ShowNoSiteProcesses, Converter={StaticResource BoolToVis}}" />

                        <ItemsControl Margin="0,12,0,0"
                                      ItemsSource="{Binding SiteProcesses}"
                                      Visibility="{Binding HasSiteProcesses, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="12,10"
                                            Background="#121A26"
                                            BorderBrush="{Binding RowBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" MinWidth="120" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0"
                                                  Width="16" Height="16"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center">
                                                <Ellipse Width="10" Height="10"
                                                         Fill="{Binding IndicatorColor}" />
                                                <Ellipse Width="16" Height="16"
                                                         Stroke="{Binding IndicatorColor}"
                                                         StrokeThickness="1"
                                                         Fill="Transparent"
                                                         Opacity="0.35" />
                                            </Grid>

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding Name}" />
                                                <StackPanel Margin="0,4,0,0"
                                                            Orientation="Horizontal">
                                                    <Border Margin="0,0,6,0"
                                                            Padding="6,2"
                                                            Background="#223047"
                                                            CornerRadius="4">
                                                        <TextBlock FontSize="11"
                                                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                                                   Text="{Binding RuntimeLabel}" />
                                                    </Border>
                                                    <Border Padding="6,2"
                                                            Background="#223047"
                                                            CornerRadius="4">
                                                        <TextBlock FontSize="11"
                                                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                                                   Text="{Binding EnabledLabel}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                                           FontSize="12"
                                                           Text="{Binding CommandLine}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding CommandLine}" />
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Margin="16,0,16,0"
                                                    Padding="8,3"
                                                    VerticalAlignment="Center"
                                                    Background="#1A4CAE8C"
                                                    CornerRadius="4"
                                                    Visibility="{Binding IsLive, Converter={StaticResource BoolToVis}}">
                                                <TextBlock FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource StackrootAccentTextBrush}"
                                                           Text="LIVE" />
                                            </Border>

                                            <TextBlock Grid.Column="3"
                                                       MinWidth="88"
                                                       Margin="0,0,16,0"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding StatusColor}"
                                                       Text="{Binding StatusText}"
                                                       TextAlignment="Right" />

                                            <WrapPanel Grid.Column="4"
                                                       VerticalAlignment="Center">
                                                <Button Content="Log"
                                                        Width="56"
                                                        Height="32"
                                                        Margin="0,0,6,0"
                                                        Padding="8,3"
                                                        Command="{Binding DataContext.ViewProcessLogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding ShowLogButton, Converter={StaticResource BoolToVis}}" />
                                                <Button Content="Start"
                                                        Width="56"
                                                        Height="32"
                                                        Margin="0,0,6,0"
                                                        Padding="8,3"
                                                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                                                        Command="{Binding DataContext.StartProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}"
                                                        Visibility="{Binding ShowStartButton, Converter={StaticResource BoolToVis}}" />
                                                <Button Content="Stop"
                                                        Width="56"
                                                        Height="32"
                                                        Margin="0,0,6,0"
                                                        Padding="8,3"
                                                        Style="{StaticResource StackrootStopButtonStyle}"
                                                        Command="{Binding DataContext.StopProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}"
                                                        Visibility="{Binding ShowStopButton, Converter={StaticResource BoolToVis}}" />
                                                <Button Content="Restart"
                                                        Width="64"
                                                        Height="32"
                                                        Margin="0,0,6,0"
                                                        Padding="8,3"
                                                        Command="{Binding DataContext.RestartProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}"
                                                        Visibility="{Binding ShowRestartButton, Converter={StaticResource BoolToVis}}" />
                                                <Button Content="Edit"
                                                        Width="56"
                                                        Height="32"
                                                        Margin="0,0,6,0"
                                                        Padding="8,3"
                                                        Command="{Binding DataContext.EditProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                                <controls:OverflowMenuButton Margin="0,0,0,0"
                                                                             DangerLabel="Remove"
                                                                             DangerCommand="{Binding DataContext.RemoveProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                             DangerCommandParameter="{Binding}"
                                                                             ButtonWidth="30"
                                                                             ButtonHeight="32" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Scheduled tasks -->
                <Border Margin="0,14,0,0"
                        Padding="14"
                        Background="{StaticResource StackrootCardBrush}"
                        BorderBrush="{StaticResource StackrootBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Scheduled tasks" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                           FontSize="12"
                                           Text="Cron-style commands for this site — runs while Stackroot is open." />
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal">
                                <Button Margin="0,0,6,0"
                                        Padding="8,4"
                                        FontSize="12"
                                        Content="All tasks"
                                        ToolTip="Open the full scheduled tasks page"
                                        Command="{Binding OpenAllScheduledTasksCommand}" />
                                <Button Margin="0,0,6,0"
                                        Padding="8,4"
                                        FontSize="12"
                                        Content="Refresh"
                                        Command="{Binding RefreshScheduledTasksCommand}" />
                                <Button Padding="8,4"
                                        FontSize="12"
                                        Content="+ Add"
                                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                                        Command="{Binding AddScheduledTaskCommand}" />
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                   FontSize="12"
                                   Text="No scheduled tasks for this site yet."
                                   Visibility="{Binding ShowNoScheduledTasks, Converter={StaticResource BoolToVis}}" />

                        <ItemsControl Margin="0,12,0,0"
                                      ItemsSource="{Binding ScheduledTasks}"
                                      Visibility="{Binding HasScheduledTasks, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6"
                                            Padding="10,8"
                                            Background="#121A26"
                                            BorderBrush="{StaticResource StackrootBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      Margin="0,0,10,0"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding IsEnabled}" />

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <WrapPanel>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding Label}" />
                                                    <TextBlock Margin="8,0,0,0"
                                                               FontFamily="Consolas"
                                                               FontSize="12"
                                                               Foreground="{StaticResource StackrootAccentTextBrush}"
                                                               Text="{Binding CronExpression}" />
                                                    <TextBlock Margin="6,0,0,0"
                                                               FontSize="11"
                                                               Foreground="{StaticResource StackrootTextMutedBrush}"
                                                               Text="{Binding CronDescription}" />
                                                </WrapPanel>
                                                <WrapPanel Margin="0,2,0,0">
                                                    <TextBlock FontSize="11"
                                                               Foreground="{StaticResource StackrootTextMutedBrush}"
                                                               FontFamily="Consolas"
                                                               Text="{Binding Command}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Margin="12,0,0,0"
                                                               FontSize="11"
                                                               Foreground="{Binding StatusColor}"
                                                               Text="{Binding StatusDisplay}" />
                                                    <TextBlock Margin="6,0,0,0"
                                                               FontSize="11"
                                                               Foreground="{StaticResource StackrootTextMutedBrush}"
                                                               Text="{Binding LastRunDisplay, StringFormat=Last: {0}}" />
                                                    <TextBlock Margin="6,0,0,0"
                                                               FontSize="11"
                                                               Foreground="{StaticResource StackrootWarnBrush}"
                                                               Text="{Binding Model.LastError}"
                                                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />
                                                </WrapPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Orientation="Horizontal">
                                                <Button Width="30"
                                                        Height="30"
                                                        Padding="0"
                                                        ToolTip="Run now"
                                                        Style="{StaticResource StackrootIconButtonStyle}"
                                                        Command="{Binding RunNowCommand}"
                                                        Content="{Binding RunButtonText}" />
                                                <Button Width="36"
                                                        Height="30"
                                                        Margin="2,0,0,0"
                                                        Padding="2"
                                                        FontSize="11"
                                                        Content="Log"
                                                        IsEnabled="{Binding HasLog}"
                                                        ToolTip="{x:Static helpers:StackrootLogViewer.CtrlClickEditorToolTip}"
                                                        PreviewMouseLeftButtonDown="OnScheduledTaskLogClick" />
                                                <Button Width="30"
                                                        Height="30"
                                                        Margin="2,0,0,0"
                                                        Padding="0"
                                                        ToolTip="Edit"
                                                        Style="{StaticResource StackrootIconButtonStyle}"
                                                        Content="✎"
                                                        Command="{Binding DataContext.EditScheduledTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                                <controls:OverflowMenuButton Margin="2,0,0,0"
                                                                             DangerLabel="Delete"
                                                                             DangerCommand="{Binding DeleteCommand}"
                                                                             ButtonWidth="30"
                                                                             ButtonHeight="30" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
    </Grid>
</UserControl>
