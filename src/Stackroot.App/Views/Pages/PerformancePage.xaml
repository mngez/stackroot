<UserControl x:Class="Stackroot.App.Views.Pages.PerformancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="PerformanceDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="BorderBrush" Value="#1E324A" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A2A3D" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#223047" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PerformanceDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="AlternatingRowBackground" Value="#131D2A" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="RowStyle" Value="{StaticResource PerformanceDataGridRowStyle}" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{DynamicResource Loc.Performance.Title}"
                       FontSize="28"
                       FontWeight="SemiBold" />

            <DockPanel Grid.Row="1"
                       Margin="0,14,0,16"
                       LastChildFill="False">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{DynamicResource Loc.Performance.Sampled}" />
                    <TextBlock Text="{Binding SampledAt}" />
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        Width="100"
                        Content="{DynamicResource Loc.Common.Refresh}"
                        Command="{Binding RefreshCommand}" />
            </DockPanel>

            <!-- App & services -->
            <Border Grid.Row="2"
                    Margin="0,0,0,16"
                    Padding="1"
                    Background="{StaticResource StackrootCardBrush}"
                    BorderBrush="{StaticResource StackrootBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <DockPanel Margin="16,14,16,10"
                               LastChildFill="False">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource Loc.Performance.AppAndServices}" />
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                                       Text="{DynamicResource Loc.Performance.TotalMemory}" />
                            <TextBlock Text="{Binding ServiceTotalMemory}" />
                        </StackPanel>
                    </DockPanel>

                    <DataGrid Style="{StaticResource PerformanceDataGridStyle}"
                              ItemsSource="{Binding ServiceItems}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColLabel}" Binding="{Binding Label}" Width="2*" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColType}" Binding="{Binding Kind}" Width="120" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColStatus}" Binding="{Binding Status}" Width="120" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColPid}" Binding="{Binding Pid}" Width="90" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColCpu}" Binding="{Binding Cpu}" Width="90" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColMemory}" Binding="{Binding Memory}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- PHP FastCGI listeners -->
            <Border Grid.Row="3"
                    Margin="0,0,0,16"
                    Padding="1"
                    Background="{StaticResource StackrootCardBrush}"
                    BorderBrush="{StaticResource StackrootBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding HasPhpListeners, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <DockPanel Margin="16,14,16,10"
                               LastChildFill="False">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource Loc.Performance.PhpListeners}" />
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                                       Text="{DynamicResource Loc.Performance.TotalMemory}" />
                            <TextBlock Text="{Binding PhpTotalMemory}" />
                        </StackPanel>
                    </DockPanel>

                    <DataGrid Style="{StaticResource PerformanceDataGridStyle}"
                              ItemsSource="{Binding PhpItems}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColVersion}" Binding="{Binding Label}" Width="*" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColEndpoint}" Binding="{Binding Endpoint}" Width="160" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColStatus}" Binding="{Binding Status}" Width="120" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColPid}" Binding="{Binding Pid}" Width="90" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColCpu}" Binding="{Binding Cpu}" Width="90" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColMemory}" Binding="{Binding Memory}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Custom processes -->
            <Border Grid.Row="4"
                    Margin="0,0,0,24"
                    Padding="1"
                    Background="{StaticResource StackrootCardBrush}"
                    BorderBrush="{StaticResource StackrootBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding HasProcesses, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <DockPanel Margin="16,14,16,10"
                               LastChildFill="False">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource Loc.Performance.CustomProcesses}" />
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                                       Text="{DynamicResource Loc.Performance.TotalMemory}" />
                            <TextBlock Text="{Binding ProcessTotalMemory}" />
                        </StackPanel>
                    </DockPanel>

                    <DataGrid Style="{StaticResource PerformanceDataGridStyle}"
                              ItemsSource="{Binding ProcessItems}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColLabel}" Binding="{Binding Label}" Width="2*" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColStatus}" Binding="{Binding Status}" Width="120" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColPid}" Binding="{Binding Pid}" Width="90" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColCpu}" Binding="{Binding Cpu}" Width="90" />
                            <DataGridTextColumn Header="{DynamicResource Loc.Performance.ColMemory}" Binding="{Binding Memory}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
