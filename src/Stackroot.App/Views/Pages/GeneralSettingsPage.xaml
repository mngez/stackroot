<UserControl x:Class="Stackroot.App.Views.Pages.GeneralSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:abstractions="clr-namespace:Stackroot.Core.Abstractions;assembly=Stackroot.Core.Abstractions"
             xmlns:helpers="clr-namespace:Stackroot.App.Helpers">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{DynamicResource Loc.GeneralSettings.Title}"
                       FontSize="28"
                       FontWeight="SemiBold" />
            <Border Margin="0,12,0,0"
                    Padding="12"
                    Background="#33E88A92"
                    BorderBrush="{StaticResource StackrootDangerTextBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding ShowCorruptedSettingsBanner, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding CorruptedSettingsBannerText}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource StackrootDangerTextBrush}" />
                    <Button Margin="0,10,0,0"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Command="{Binding RestoreFromBackupCommand}"
                            Visibility="{Binding ShowRestoreBackupButton, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource Loc.GeneralSettings.RestoreFromBackup}" />
                    </Button>
                </StackPanel>
            </Border>
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{DynamicResource Loc.GeneralSettings.Subtitle}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{DynamicResource Loc.GeneralSettings.AutoSave}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,20,0,24"
                Padding="16"
                Background="{StaticResource StackrootCardBrush}"
                BorderBrush="{StaticResource StackrootBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Loc.GeneralSettings.AppDomain}" Foreground="{StaticResource StackrootTextMutedBrush}" />
                    <TextBox Margin="0,6,0,0"
                             Padding="10,6"
                             Text="{Binding AppDomain, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,16,0,0" Text="{DynamicResource Loc.GeneralSettings.WwwPath}" Foreground="{StaticResource StackrootTextMutedBrush}" />
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Margin="0,0,8,0"
                                 Padding="10,6"
                                 Text="{Binding WwwPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Width="90"
                                Command="{Binding BrowseWwwCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Image Width="14"
                                       Height="14"
                                       Margin="0,0,4,0"
                                       VerticalAlignment="Center"
                                       Source="{x:Static helpers:StackrootImages.FolderIcon}"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock VerticalAlignment="Center"
                                           Text="{DynamicResource Loc.Common.Browse}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               FontSize="12"
                               Text="{Binding DefaultWwwPath, StringFormat=Default: {0}}" />
                    <Button Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource StackrootAccentTextBrush}"
                            Content="{DynamicResource Loc.Common.UseDefault}"
                            Command="{Binding UseDefaultWwwCommand}" />

                    <TextBlock Margin="0,16,0,0" Text="{DynamicResource Loc.GeneralSettings.BackupsPath}" Foreground="{StaticResource StackrootTextMutedBrush}" />
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Margin="0,0,8,0"
                                 Padding="10,6"
                                 Text="{Binding BackupsPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Width="90"
                                Command="{Binding BrowseBackupsPathCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Image Width="14"
                                       Height="14"
                                       Margin="0,0,4,0"
                                       VerticalAlignment="Center"
                                       Source="{x:Static helpers:StackrootImages.FolderIcon}"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock VerticalAlignment="Center"
                                           Text="{DynamicResource Loc.Common.Browse}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               FontSize="12"
                               Text="{Binding DefaultBackupsPath, StringFormat=Default: {0}}" />
                    <Button Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource StackrootAccentTextBrush}"
                            Content="{DynamicResource Loc.Common.UseDefault}"
                            Command="{Binding UseDefaultBackupsPathCommand}" />

                    <TextBlock Margin="0,16,0,0" Text="{DynamicResource Loc.GeneralSettings.PreferredEditor}" Foreground="{StaticResource StackrootTextMutedBrush}" />
                    <ComboBox Margin="0,6,0,0"
                              Padding="8,4"
                              ItemsSource="{Binding EditorOptions}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding PreferredEditor}" />

                    <StackPanel Margin="0,12,0,0"
                                Visibility="{Binding ShowCustomEditorPath, Converter={StaticResource BoolToVis}}">
                        <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}" Text="{DynamicResource Loc.GeneralSettings.CustomEditorPath}" />
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Margin="0,0,8,0"
                                     Padding="10,6"
                                     Text="{Binding CustomEditorPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Width="90"
                                    Content="{DynamicResource Loc.Common.Browse}"
                                    Command="{Binding BrowseEditorCommand}" />
                        </Grid>
                    </StackPanel>

                    <TextBlock Margin="0,16,0,0" Text="{DynamicResource Loc.GeneralSettings.CloseBehavior}" Foreground="{StaticResource StackrootTextMutedBrush}" />
                    <ComboBox Margin="0,6,0,0"
                              Padding="8,4"
                              SelectedItem="{Binding CloseBehavior}">
                        <abstractions:CloseBehavior>Ask</abstractions:CloseBehavior>
                        <abstractions:CloseBehavior>Quit</abstractions:CloseBehavior>
                        <abstractions:CloseBehavior>Background</abstractions:CloseBehavior>
                    </ComboBox>

                    <TextBlock Margin="0,16,0,0" Text="{DynamicResource Loc.GeneralSettings.LogRetention}" Foreground="{StaticResource StackrootTextMutedBrush}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               FontSize="12"
                               Text="{DynamicResource Loc.GeneralSettings.LogRetentionHint}"
                               TextWrapping="Wrap" />
                    <TextBox Margin="0,6,0,0"
                             Padding="10,6"
                             Text="{Binding LogRetentionDays, UpdateSourceTrigger=PropertyChanged}" />

                    <CheckBox Margin="0,16,0,0"
                              Content="{DynamicResource Loc.GeneralSettings.AddBinToPath}"
                              IsChecked="{Binding AddBinToPath}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{DynamicResource Loc.GeneralSettings.AddBinToPathHint}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{Binding BinPathPreview, StringFormat=Bin path: {0}}" />

                    <CheckBox Margin="0,16,0,0"
                              Content="{DynamicResource Loc.GeneralSettings.LaunchAtStartup}"
                              IsChecked="{Binding LaunchAtStartup}" />
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox VerticalAlignment="Center"
                                  Content="{DynamicResource Loc.GeneralSettings.ShowMetrics}"
                                  IsChecked="{Binding ShellMetricsEnabled}" />
                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding ShowShellMetricsCpuRefresh, Converter={StaticResource BoolToVis}}">
                            <TextBlock Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                       Text="{DynamicResource Loc.GeneralSettings.CpuEvery}" />
                            <TextBox Width="52"
                                     Padding="8,4"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding ShellMetricsCpuRefreshSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                       Text="{DynamicResource Loc.GeneralSettings.Sec}" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{Binding ShellMetricsCpuRefreshHint}"
                               TextWrapping="Wrap"
                               Visibility="{Binding ShowShellMetricsCpuRefresh, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{DynamicResource Loc.GeneralSettings.MetricsHint}"
                               TextWrapping="Wrap" />

                    <CheckBox Margin="0,16,0,0"
                              Content="{DynamicResource Loc.GeneralSettings.Thumbnails}"
                              IsChecked="{Binding ThumbnailsEnabled}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{DynamicResource Loc.GeneralSettings.ThumbnailsHint}"
                               TextWrapping="Wrap" />

                    <CheckBox Margin="0,16,0,0"
                              Content="{DynamicResource Loc.GeneralSettings.TrustSslCa}"
                              IsChecked="{Binding TrustSslCaMachineWide}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{DynamicResource Loc.GeneralSettings.TrustSslHint}"
                               TextWrapping="Wrap" />

                    <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                        <Button Width="160"
                                Content="{DynamicResource Loc.GeneralSettings.TrustSsl}"
                                Command="{Binding TrustSslCommand}" />
                        <Button Margin="8,0,0,0"
                                Width="160"
                                Content="{DynamicResource Loc.GeneralSettings.RemoveOldCas}"
                                Command="{Binding CleanupSslTrustCommand}" />
                        <TextBlock Margin="12,8,0,0"
                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                   Text="{Binding StatusMessage}" />
                    </StackPanel>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{DynamicResource Loc.GeneralSettings.SslWarning}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,16,0,0" Text="{DynamicResource Loc.GeneralSettings.Language}" Foreground="{StaticResource StackrootTextMutedBrush}" />
                    <ComboBox Margin="0,6,0,0"
                              Padding="8,4"
                              MaxWidth="260"
                              HorizontalAlignment="Left"
                              ItemsSource="{Binding AvailableLanguages}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Code"
                              SelectedValue="{Binding Language}" />
                </StackPanel>
            </Border>
    </Grid>
</UserControl>
