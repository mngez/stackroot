<UserControl x:Class="Stackroot.App.Views.Pages.GeneralSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:abstractions="clr-namespace:Stackroot.Core.Abstractions;assembly=Stackroot.Core.Abstractions"
             xmlns:helpers="clr-namespace:Stackroot.App.Helpers">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="General Settings"
                       FontSize="28"
                       FontWeight="SemiBold" />
            <Border Margin="0,12,0,0"
                    Padding="12"
                    Background="#33E88A92"
                    BorderBrush="{StaticResource StackrootDangerTextBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding ShowCorruptedSettingsBanner, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding CorruptedSettingsBannerText}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource StackrootDangerTextBrush}" />
                    <Button Margin="0,10,0,0"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Command="{Binding RestoreFromBackupCommand}"
                            Visibility="{Binding ShowRestoreBackupButton, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Restore from backup" />
                    </Button>
                </StackPanel>
            </Border>
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Configure base paths, app behavior, and environment defaults" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Changes are saved automatically." />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,20,0,24"
                Padding="16"
                Background="{StaticResource StackrootCardBrush}"
                BorderBrush="{StaticResource StackrootBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="App domain" Foreground="{StaticResource StackrootTextMutedBrush}" />
                    <TextBox Margin="0,6,0,0"
                             Padding="10,6"
                             Text="{Binding AppDomain, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,16,0,0" Text="WWW path" Foreground="{StaticResource StackrootTextMutedBrush}" />
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Margin="0,0,8,0"
                                 Padding="10,6"
                                 Text="{Binding WwwPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Width="90"
                                Command="{Binding BrowseWwwCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Image Width="14"
                                       Height="14"
                                       Margin="0,0,4,0"
                                       VerticalAlignment="Center"
                                       Source="{x:Static helpers:StackrootImages.FolderIcon}"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock VerticalAlignment="Center"
                                           Text="Browse…" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               FontSize="12"
                               Text="{Binding DefaultWwwPath, StringFormat=Default: {0}}" />
                    <Button Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource StackrootAccentTextBrush}"
                            Content="Use default"
                            Command="{Binding UseDefaultWwwCommand}" />

                    <TextBlock Margin="0,16,0,0" Text="Preferred editor" Foreground="{StaticResource StackrootTextMutedBrush}" />
                    <ComboBox Margin="0,6,0,0"
                              Padding="8,4"
                              ItemsSource="{Binding EditorOptions}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding PreferredEditor}" />

                    <StackPanel Margin="0,12,0,0"
                                Visibility="{Binding ShowCustomEditorPath, Converter={StaticResource BoolToVis}}">
                        <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}" Text="Custom editor path" />
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Margin="0,0,8,0"
                                     Padding="10,6"
                                     Text="{Binding CustomEditorPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Width="90"
                                    Content="Browse…"
                                    Command="{Binding BrowseEditorCommand}" />
                        </Grid>
                    </StackPanel>

                    <TextBlock Margin="0,16,0,0" Text="Close behavior" Foreground="{StaticResource StackrootTextMutedBrush}" />
                    <ComboBox Margin="0,6,0,0"
                              Padding="8,4"
                              SelectedItem="{Binding CloseBehavior}">
                        <abstractions:CloseBehavior>Ask</abstractions:CloseBehavior>
                        <abstractions:CloseBehavior>Quit</abstractions:CloseBehavior>
                        <abstractions:CloseBehavior>Background</abstractions:CloseBehavior>
                    </ComboBox>

                    <TextBlock Margin="0,16,0,0" Text="Log retention (days)" Foreground="{StaticResource StackrootTextMutedBrush}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               FontSize="12"
                               Text="Set to 0 to disable automatic cleanup."
                               TextWrapping="Wrap" />
                    <TextBox Margin="0,6,0,0"
                             Padding="10,6"
                             Text="{Binding LogRetentionDays, UpdateSourceTrigger=PropertyChanged}" />

                    <CheckBox Margin="0,16,0,0"
                              Content="Use Stackroot-managed php/composer/node shims in PATH (opt-in)"
                              IsChecked="{Binding AddBinToPath}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="When disabled, Stackroot does not override your system php, composer, or node commands."
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{Binding BinPathPreview, StringFormat=Bin path: {0}}" />

                    <CheckBox Margin="0,16,0,0"
                              Content="Launch Stackroot when Windows starts"
                              IsChecked="{Binding LaunchAtStartup}" />
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox VerticalAlignment="Center"
                                  Content="Show RAM and CPU in the shell header"
                                  IsChecked="{Binding ShellMetricsEnabled}" />
                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding ShowShellMetricsCpuRefresh, Converter={StaticResource BoolToVis}}">
                            <TextBlock Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                       Text="CPU every" />
                            <TextBox Width="52"
                                     Padding="8,4"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding ShellMetricsCpuRefreshSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                       Text="sec" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{Binding ShellMetricsCpuRefreshHint}"
                               TextWrapping="Wrap"
                               Visibility="{Binding ShowShellMetricsCpuRefresh, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="Lightweight summary with a link to the Performance page. Turn off for a cleaner header."
                               TextWrapping="Wrap" />

                    <CheckBox Margin="0,16,0,0"
                              Content="Enable site thumbnails (downloads ~300 MB Chromium browser on first use)"
                              IsChecked="{Binding ThumbnailsEnabled}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="When enabled, a headless browser captures screenshots of your sites for the dashboard."
                               TextWrapping="Wrap" />

                    <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                        <Button Width="160"
                                Content="Trust SSL"
                                Command="{Binding TrustSslCommand}" />
                        <TextBlock Margin="12,8,0,0"
                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                   Text="{Binding StatusMessage}" />
                    </StackPanel>
                </StackPanel>
            </Border>
    </Grid>
</UserControl>
