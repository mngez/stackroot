<UserControl x:Class="Stackroot.App.Views.Pages.DatabasesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Stackroot.App.Views.Controls">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <StackPanel>
                <TextBlock Text="{DynamicResource Loc.Databases.Title}"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{Binding CredentialsSummary, Mode=OneWay}" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right"
                        Style="{StaticResource StackrootPageActionsStyle}">
                <Button Style="{StaticResource StackrootIconButtonStyle}"
                        Margin="0,0,10,0"
                        ToolTip="{DynamicResource Loc.Databases.SettingsTooltip}"
                        Command="{Binding OpenSettingsCommand}">
                    <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                               FontSize="14"
                               Text="&#xE713;" />
                </Button>
                <Button MinWidth="116"
                        MinHeight="36"
                        Margin="0,0,10,0"
                        Padding="14,8"
                        Content="{DynamicResource Loc.Common.Backups}"
                        Command="{Binding OpenBackupsCommand}" />
                <Button MinWidth="116"
                        MinHeight="36"
                        Margin="0,0,10,0"
                        Padding="14,8"
                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                        Content="{DynamicResource Loc.Databases.CreateButton}"
                        Command="{Binding OpenCreateDialogCommand}" />
                <Button MinWidth="100"
                        Content="{DynamicResource Loc.Common.Refresh}"
                        Command="{Binding RefreshCommand}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                Padding="12"
                Background="{StaticResource StackrootCardBrush}"
                BorderBrush="{StaticResource StackrootBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.4*" />
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                               FontSize="12"
                               Text="{DynamicResource Loc.Databases.Search}" />
                    <TextBox Margin="0,6,0,0"
                             Padding="10,6"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                               FontSize="12"
                               Text="{DynamicResource Loc.Databases.Engine}" />
                    <ComboBox Margin="0,6,0,0"
                              Padding="8,4"
                              ItemsSource="{Binding EngineFilters}"
                              DisplayMemberPath="Label"
                              SelectedItem="{Binding SelectedEngineFilter}" />
                </StackPanel>

                <Button Grid.Column="2"
                        MinWidth="88"
                        MinHeight="36"
                        Margin="0,22,0,0"
                        VerticalAlignment="Bottom"
                        Padding="14,8"
                        Content="{DynamicResource Loc.Common.Clear}"
                        Command="{Binding ClearFiltersCommand}" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="0,10,0,0"
                   Foreground="{StaticResource StackrootTextMutedBrush}"
                   Text="{DynamicResource Loc.Databases.NoMatch}"
                   Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVis}}" />

        <Border Grid.Row="3"
                Margin="0,16,0,0"
                Padding="1"
                Background="{StaticResource StackrootCardBrush}"
                BorderBrush="{StaticResource StackrootBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Visibility="{Binding HasDatabases, Converter={StaticResource BoolToVis}}">
            <DataGrid AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      Background="Transparent"
                      AlternationCount="2"
                      AlternatingRowBackground="#131D2A"
                      RowBackground="Transparent"
                      ItemsSource="{Binding Databases}"
                      SelectedItem="{Binding SelectedDatabase, Mode=TwoWay}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="MinHeight" Value="40" />
                        <Setter Property="BorderBrush" Value="#1E324A" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A2A3D" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#223047" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource Loc.Databases.ColName}" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="{DynamicResource Loc.Databases.ColEngine}" Binding="{Binding Engine}" Width="*" />
                    <DataGridTextColumn Header="{DynamicResource Loc.Databases.ColCreated}" Binding="{Binding CreatedAt}" Width="1.6*" />
                    <DataGridTextColumn Header="{DynamicResource Loc.Databases.ColLastBackup}" Binding="{Binding LastBackupAt}" Width="1.6*" />
                    <DataGridTemplateColumn Header="{DynamicResource Loc.Databases.ColActions}" Width="315">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content=".env"
                                            Margin="0,0,6,0"
                                            Padding="8,3"
                                            MinHeight="26"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.OpenRowEnvCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Name}" />
                                    <Button Content="{DynamicResource Loc.Common.Backups}"
                                            Margin="0,0,6,0"
                                            Padding="8,3"
                                            MinHeight="26"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.OpenRowBackupsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Name}" />
                                    <Button Content="{DynamicResource Loc.Databases.Backup}"
                                            Margin="0,0,6,0"
                                            Padding="8,3"
                                            MinHeight="26"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.BackupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Name}" />
                                    <controls:OverflowMenuButton Margin="0,0,0,0"
                                                                 DangerLabel="{DynamicResource Loc.Common.Delete}"
                                                                 DangerCommand="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 DangerCommandParameter="{Binding Name}"
                                                                 ButtonWidth="30"
                                                                 ButtonHeight="26" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <controls:DismissibleNoticeBanner Grid.Row="4"
                                          Margin="0,10,0,24"
                                          Text="{Binding LastMessage}"
                                          DismissCommand="{Binding DismissLastMessageCommand}" />

        <controls:OperationBusyOverlay Grid.RowSpan="5" />
    </Grid>
</UserControl>
