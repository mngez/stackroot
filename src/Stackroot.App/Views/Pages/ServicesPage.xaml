<UserControl x:Class="Stackroot.App.Views.Pages.ServicesPage"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:helpers="clr-namespace:Stackroot.App.Helpers"
             xmlns:controls="clr-namespace:Stackroot.App.Views.Controls">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />

    </UserControl.Resources>

    <Grid Margin="24">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <DockPanel Grid.Row="0" LastChildFill="False">

            <StackPanel>

                <TextBlock Text="{DynamicResource Loc.Services.Title}"

                           FontSize="28"

                           FontWeight="SemiBold" />

                <TextBlock Margin="0,6,0,0"

                           Foreground="{StaticResource StackrootTextMutedBrush}"

                           Text="{DynamicResource Loc.Services.Subtitle}" />

            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Style="{StaticResource StackrootPageActionsStyle}">

                <Button MinWidth="132"
                        MinHeight="36"
                        Margin="0,0,10,0"
                        Padding="14,8"
                        ToolTip="{DynamicResource Loc.Services.RebuildTooltip}"
                        Content="{DynamicResource Loc.Common.Rebuild}"
                        Command="{Binding RebuildNginxCommand}" />

                <Button MinWidth="100"
                        Content="{DynamicResource Loc.Common.Refresh}"
                        Command="{Binding RefreshCommand}" />

            </StackPanel>

        </DockPanel>

        <controls:DismissibleNoticeBanner Grid.Row="1"
                                          Margin="0,12,0,0"
                                          Text="{Binding StackNotice}"
                                          DismissCommand="{Binding DismissStackNoticeCommand}" />

        <StackPanel Grid.Row="2"

                    Margin="0,20,0,24">

                <ItemsControl ItemsSource="{Binding Groups}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Border Margin="0,0,0,12"

                                    Padding="12"

                                    Background="{StaticResource StackrootCardBrush}"

                                    BorderBrush="{StaticResource StackrootBorderBrush}"

                                    BorderThickness="1"

                                    CornerRadius="10">

                                <StackPanel>

                                    <TextBlock FontSize="16"

                                               FontWeight="SemiBold"

                                               Text="{Binding Title}" />

                                    <ItemsControl Margin="0,10,0,0"

                                                  ItemsSource="{Binding Items}">

                                        <ItemsControl.ItemTemplate>

                                            <DataTemplate>

                                                <Border Margin="0,0,0,8"

                                                        Padding="10"

                                                        Background="{Binding RowBackgroundBrush}"

                                                        BorderBrush="{Binding RowBorderBrush}"

                                                        BorderThickness="1"

                                                        CornerRadius="8"

                                                        Opacity="{Binding RowOpacity}">

                                                    <Grid Margin="4,0">

                                                        <Grid.ColumnDefinitions>

                                                            <ColumnDefinition Width="Auto" />

                                                            <ColumnDefinition Width="*" MinWidth="100" />

                                                            <ColumnDefinition Width="Auto" MinWidth="200" MaxWidth="280" />

                                                            <ColumnDefinition Width="Auto" />

                                                        </Grid.ColumnDefinitions>



                                                        <Grid Grid.Column="0"
                                                              Width="16"
                                                              Height="16"
                                                              Margin="0,0,8,0"
                                                              VerticalAlignment="Center">
                                                            <Ellipse Width="10"
                                                                     Height="10"
                                                                     Fill="{Binding IndicatorColor}" />
                                                            <Ellipse Width="16"
                                                                     Height="16"
                                                                     Stroke="{Binding IndicatorColor}"
                                                                     StrokeThickness="1"
                                                                     Fill="Transparent"
                                                                     Opacity="0.35" />
                                                        </Grid>



                                                        <StackPanel Grid.Column="1"

                                                                    Margin="0,0,32,0"

                                                                    VerticalAlignment="Center">

                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock FontSize="14"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding Name}" />
                                                                <TextBlock Margin="5,0,0,0"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="12"
                                                                           Foreground="#4CAE8C"
                                                                           Text="⚡"
                                                                           ToolTip="{DynamicResource Loc.Common.KeepAliveActive}"
                                                                           Visibility="{Binding IsSupervised, Converter={StaticResource BoolToVis}}" />
                                                            </StackPanel>

                                                            <TextBlock Margin="0,4,0,0"

                                                                       Foreground="{StaticResource StackrootTextMutedBrush}"

                                                                       Text="{Binding Description}" />

                                                            <TextBlock Margin="0,4,0,0"

                                                                       Foreground="{StaticResource StackrootTextMutedBrush}"

                                                                       Text="{Binding DetailsText}"

                                                                       Visibility="{Binding HasDetailsText, Converter={StaticResource BoolToVis}}" />

                                                            <ProgressBar Margin="0,8,0,0"

                                                                         Height="5"

                                                                         Maximum="100"

                                                                         Value="{Binding InstallPercent, Mode=OneWay}"

                                                                         Visibility="{Binding ShowInstallProgress, Converter={StaticResource BoolToVis}}" />

                                                        </StackPanel>



                                                        <ComboBox Grid.Column="2"

                                                                  MinWidth="200"

                                                                  MaxWidth="280"

                                                                  Margin="0,0,40,0"

                                                                  Padding="8,4"

                                                                  HorizontalAlignment="Left"

                                                                  VerticalAlignment="Center"

                                                                  helpers:ComboBoxDropDownSizer.IsEnabled="True"

                                                                  ItemsSource="{Binding InstalledVersions}"

                                                                  DisplayMemberPath="Label"

                                                                  SelectedValuePath="Id"

                                                                  SelectedValue="{Binding SelectedPackageId}"

                                                                  Visibility="{Binding ShowVersionCombo, Converter={StaticResource BoolToVis}}" />



                                                        <StackPanel Grid.Column="3"

                                                                    VerticalAlignment="Center"

                                                                    HorizontalAlignment="Right">

                                                            <TextBlock Margin="0,0,0,6"

                                                                       MaxWidth="280"

                                                                       HorizontalAlignment="Right"

                                                                       FontSize="11"

                                                                       Foreground="{StaticResource StackrootAccentTextBrush}"

                                                                       Text="{Binding Message}"

                                                                       TextWrapping="Wrap"

                                                                       Visibility="{Binding HasMessage, Converter={StaticResource BoolToVis}}" />

                                                            <StackPanel Orientation="Horizontal"

                                                                        HorizontalAlignment="Right">

                                                                <Border Margin="0,0,12,0"

                                                                        Padding="8,3"

                                                                        VerticalAlignment="Center"

                                                                        Background="#1A4CAE8C"

                                                                        CornerRadius="4"

                                                                        Visibility="{Binding IsLive, Converter={StaticResource BoolToVis}}">

                                                                    <TextBlock FontSize="11"

                                                                               FontWeight="Bold"

                                                                               Foreground="{StaticResource StackrootAccentTextBrush}"

                                                                               Text="{DynamicResource Loc.Status.LiveBadge}" />

                                                                </Border>



                                                                <StackPanel MinWidth="120"

                                                                            MaxWidth="168"

                                                                            Margin="0,0,16,0"

                                                                            VerticalAlignment="Center"

                                                                            HorizontalAlignment="Right">

                                                                    <TextBlock HorizontalAlignment="Right"

                                                                               FontWeight="SemiBold"

                                                                               Foreground="{Binding StatusColor}"

                                                                               Text="{Binding StatusText, Converter={StaticResource StatusTextConverter}}"

                                                                               TextAlignment="Right"

                                                                               TextTrimming="CharacterEllipsis"

                                                                               ToolTip="{Binding StatusText, Converter={StaticResource StatusTextConverter}}" />

                                                                    <ProgressBar Margin="0,5,0,0"

                                                                                 Height="3"

                                                                                 IsIndeterminate="True"

                                                                                 Visibility="{Binding ShowBusyIndicator, Converter={StaticResource BoolToVis}}" />

                                                                </StackPanel>



                                                                <Button Width="36"

                                                                        Height="36"

                                                                        Margin="0,0,8,0"

                                                                        Style="{StaticResource StackrootIconButtonStyle}"

                                                                        ToolTip="{DynamicResource Loc.Common.Settings}"

                                                                        Command="{Binding SettingsCommand}"

                                                                        Visibility="{Binding ShowSettingsButton, Converter={StaticResource BoolToVis}}">

                                                                    <TextBlock FontFamily="{StaticResource StackrootIconFont}"

                                                                               FontSize="14"

                                                                               Text="&#xE713;" />

                                                                </Button>



                                                                <Button Width="36"

                                                                        Height="36"

                                                                        Margin="0,0,8,0"

                                                                        Style="{StaticResource StackrootPrimaryIconButtonStyle}"

                                                                        ToolTip="{DynamicResource Loc.Tools.InstallTooltip}"

                                                                        Command="{Binding InstallCommand}"

                                                                        Visibility="{Binding ShowInstallButton, Converter={StaticResource BoolToVis}}">

                                                                    <TextBlock FontFamily="{StaticResource StackrootIconFont}"

                                                                               FontSize="14"

                                                                               Text="&#xE896;" />

                                                                </Button>



                                                                <Button Width="36"

                                                                        Height="36"

                                                                        Style="{StaticResource StackrootIconButtonStyle}"

                                                                        ToolTip="{DynamicResource Loc.Tools.VersionsTooltip}"

                                                                        Command="{Binding VersionsCommand}"

                                                                        Visibility="{Binding ShowVersionsButton, Converter={StaticResource BoolToVis}}">

                                                                    <TextBlock FontFamily="{StaticResource StackrootIconFont}"

                                                                               FontSize="14"

                                                                               Text="&#xE8FD;" />

                                                                </Button>

                                                            </StackPanel>

                                                        </StackPanel>

                                                    </Grid>

                                                </Border>

                                            </DataTemplate>

                                        </ItemsControl.ItemTemplate>

                                    </ItemsControl>

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

    </Grid>

</UserControl>
