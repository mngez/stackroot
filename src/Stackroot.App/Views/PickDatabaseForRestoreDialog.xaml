<Window x:Class="Stackroot.App.Views.PickDatabaseForRestoreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:Stackroot.App.Windows"
        Title="Restore backup — pick database"
        Width="400" Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False"
        windows:WindowsTheme.EnableDarkTitleBar="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="16" FontWeight="SemiBold"
                   Text="Select target database" />
        <TextBlock Grid.Row="1" Margin="0,8,0,0"
                   Foreground="{StaticResource StackrootTextMutedBrush}"
                   Text="Choose which database to restore this backup into:" TextWrapping="Wrap" />

        <ComboBox Grid.Row="2" Margin="0,14,0,0" Padding="8,6"
                  ItemsSource="{Binding Databases}"
                  SelectedItem="{Binding SelectedDatabase}" />

        <StackPanel Grid.Row="3" Margin="0,16,0,0"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" MinWidth="80" Padding="10,6"
                    Command="{Binding CancelCommand}" />
            <Button Content="Restore" MinWidth="80" Padding="10,6" Margin="8,0,0,0"
                    Style="{StaticResource StackrootPrimaryButtonStyle}"
                    Command="{Binding RestoreCommand}" />
        </StackPanel>
    </Grid>
</Window>
