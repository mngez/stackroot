<Window x:Class="Stackroot.App.Views.PickDatabaseForRestoreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:Stackroot.App.Windows"
        Title="{DynamicResource Loc.PickDatabase.Title}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="440" Height="320"
        MinHeight="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False"
        windows:WindowsTheme.EnableDarkTitleBar="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="16" FontWeight="SemiBold"
                   Text="{DynamicResource Loc.PickDatabase.Title}" />
        <TextBlock Grid.Row="1" Margin="0,8,0,0"
                   Foreground="{StaticResource StackrootTextMutedBrush}"
                   Text="{DynamicResource Loc.PickDatabase.Subtitle}"
                   TextWrapping="Wrap" />

        <ComboBox Grid.Row="2" Margin="0,14,0,0" Padding="8,6"
                  ItemsSource="{Binding Databases}"
                  SelectedItem="{Binding SelectedDatabase}" />

        <CheckBox Grid.Row="3"
                  Margin="0,14,0,0"
                  Content="{DynamicResource Loc.PickDatabase.Replace}"
                  IsChecked="{Binding ReplaceDatabaseBeforeRestore}"
                  ToolTip="{DynamicResource Loc.PickDatabase.ReplaceTooltip}" />

        <CheckBox Grid.Row="4"
                  Margin="0,10,0,0"
                  Content="{DynamicResource Loc.PickDatabase.DisableForeignKeyChecks}"
                  IsChecked="{Binding DisableForeignKeyChecks}"
                  ToolTip="{DynamicResource Loc.PickDatabase.DisableForeignKeyChecksTooltip}" />

        <StackPanel Grid.Row="6" Margin="0,16,0,0"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Loc.Common.Cancel}"
                    MinWidth="80" Padding="10,6"
                    Command="{Binding CancelCommand}" />
            <Button Content="{DynamicResource Loc.Common.Restore}"
                    MinWidth="80" Padding="10,6" Margin="8,0,0,0"
                    Style="{StaticResource StackrootPrimaryButtonStyle}"
                    Command="{Binding RestoreCommand}" />
        </StackPanel>
    </Grid>
</Window>
