<UserControl x:Class="Stackroot.App.Views.Controls.SiteCustomCommandsToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Stackroot.App.Helpers">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <StackPanel>
        <ItemsControl ItemsSource="{Binding ActiveCommandStatuses}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,4"
                            Padding="10,8"
                            Background="#121A26"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    Margin="8,0,0,0"
                                    ToolTip="{DynamicResource Loc.Common.Dismiss}"
                                    Style="{StaticResource StackrootIconButtonStyle}"
                                    Command="{Binding DataContext.DismissCustomStatusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding ShowDismissStatus, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                           FontSize="12"
                                           Text="&#xE711;" />
                            </Button>
                            <Button DockPanel.Dock="Right"
                                    Margin="8,0,0,0"
                                    Padding="8,4"
                                    FontSize="12"
                                    Content="{Binding CancelButtonLabel}"
                                    IsEnabled="{Binding CanCancelCommand}"
                                    Command="{Binding CancelCommand}"
                                    Visibility="{Binding ShowCancelStatus, Converter={StaticResource BoolToVis}}" />
                            <Button DockPanel.Dock="Right"
                                    Margin="8,0,0,0"
                                    Padding="8,4"
                                    FontSize="12"
                                    Content="{DynamicResource Loc.Common.ViewLog}"
                                    ToolTip="{x:Static helpers:StackrootLogViewer.CtrlClickEditorToolTip}"
                                    PreviewMouseLeftButtonDown="OnCustomCommandViewLogClick"
                                    Visibility="{Binding ShowViewLogButton, Converter={StaticResource BoolToVis}}" />
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                       FontSize="12"
                                       Text="{Binding Status}" />
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl Margin="0,4,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Margin="0,4,8,4"
                            Padding="10,6"
                            ToolTip="{Binding Command}"
                            Command="{Binding RunCommand}"
                            Style="{StaticResource StackrootCustomCommandButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="16"
                                   Height="16"
                                   Margin="0,0,6,0"
                                   Source="{Binding IconSource}"
                                   Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                            <TextBlock VerticalAlignment="Center" Text="{Binding DisplayLabel}" />
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <ItemsControl.ItemsSource>
                <CompositeCollection>
                    <Button Margin="0,4,8,4"
                            Padding="10,6"
                            Content="{DynamicResource Loc.Common.OpenSite}"
                            Style="{StaticResource StackrootPrimaryButtonStyle}"
                            Command="{Binding OpenSiteCommand}"
                            Visibility="{Binding ShowOpenSiteButton, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}" />
                    <Button Margin="0,4,8,4"
                            Padding="10,6"
                            Content="{DynamicResource Loc.Common.OpenAdmin}"
                            Command="{Binding OpenPostInstallAdminCommand}"
                            Visibility="{Binding ShowOpenAdminButton, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}" />
                    <CollectionContainer Collection="{Binding CustomCommandItems}" />
                    <Button Margin="0,4,8,4"
                            Width="32"
                            Height="32"
                            ToolTip="{DynamicResource Loc.Common.ManageCustomCommands}"
                            Style="{StaticResource StackrootPrimaryIconButtonStyle}"
                            Command="{Binding ManageCustomCommandsCommand}">
                        <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                   FontSize="14"
                                   Text="&#xE8FD;" />
                    </Button>
                </CompositeCollection>
            </ItemsControl.ItemsSource>
        </ItemsControl>
    </StackPanel>
</UserControl>
