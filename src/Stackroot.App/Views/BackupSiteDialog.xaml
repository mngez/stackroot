<Window x:Class="Stackroot.App.Views.BackupSiteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:Stackroot.App.Windows"
        Title="{DynamicResource Loc.BackupSiteDialog.Title}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="780"
        MinWidth="600"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False"
        windows:WindowsTheme.EnableDarkTitleBar="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── LEFT PANEL: backup options ── -->
        <Grid Grid.Column="0" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0">
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="{DynamicResource Loc.BackupSiteDialog.Title}" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{Binding SiteDomain}"
                           FontSize="13" />
            </StackPanel>

            <!-- Options -->
            <StackPanel Grid.Row="1" Margin="0,16,0,0">

                <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                           FontSize="12"
                           Margin="0,0,0,10"
                           Text="{DynamicResource Loc.BackupSiteDialog.IncludeLabel}" />

                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding IncludeFiles}"
                          Content="{DynamicResource Loc.BackupSiteDialog.IncludeFiles}" />
                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding IncludeDatabases}"
                          Visibility="{Binding HasDatabases, Converter={StaticResource BoolToVis}}"
                          Content="{DynamicResource Loc.BackupSiteDialog.IncludeDatabases}" />
                <CheckBox Margin="0,0,0,8"
                          IsChecked="{Binding IncludeProcesses}"
                          Visibility="{Binding HasProcesses, Converter={StaticResource BoolToVis}}"
                          Content="{DynamicResource Loc.BackupSiteDialog.IncludeProcesses}" />
                <CheckBox Margin="0,0,0,16"
                          IsChecked="{Binding IncludeScheduledTasks}"
                          Visibility="{Binding HasScheduledTasks, Converter={StaticResource BoolToVis}}"
                          Content="{DynamicResource Loc.BackupSiteDialog.IncludeScheduledTasks}" />

                <Separator Margin="0,0,0,16"
                           Background="{StaticResource StackrootBorderBrush}" />

                <CheckBox IsChecked="{Binding DeleteSiteAfterBackup}"
                          Content="{DynamicResource Loc.BackupSiteDialog.DeleteSiteAfterBackup}" />

            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">

                <Button Width="88"
                        Margin="0,0,8,0"
                        Content="{DynamicResource Loc.Common.Cancel}"
                        Command="{Binding CancelCommand}" />

                <Button Width="110"
                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                        Content="{Binding StartLabel}"
                        Command="{Binding StartCommand}" />

            </StackPanel>
        </Grid>

        <!-- ── COLUMN SEPARATOR ── -->
        <Border Grid.Column="1"
                Background="{StaticResource StackrootBorderBrush}" />

        <!-- ── RIGHT PANEL: what will happen ── -->
        <Grid Grid.Column="2" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,14"
                       Text="{DynamicResource Loc.BackupSiteDialog.Preview.Title}" />

            <StackPanel Grid.Row="1">

                <!-- Backup-only info -->
                <Border Padding="12,10"
                        Background="#0D5BA3F5"
                        BorderBrush="#3D5BA3F5"
                        BorderThickness="1"
                        CornerRadius="6"
                        Visibility="{Binding ShowBackupOnlyPreview, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                       FontSize="14"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="#5BA3F5"
                                       Text="&#xE946;" />
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="#5BA3F5"
                                       Text="{DynamicResource Loc.BackupSiteDialog.Preview.BackupOnly.Title}" />
                        </StackPanel>
                        <TextBlock FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource StackrootTextMutedBrush}"
                                   Text="{DynamicResource Loc.BackupSiteDialog.Preview.BackupOnly.Desc}" />
                    </StackPanel>
                </Border>

                <!-- Archive warning -->
                <StackPanel Visibility="{Binding ShowDeletePreview, Converter={StaticResource BoolToVis}}">

                    <Border Margin="0,0,0,12"
                            Padding="12,10"
                            Background="#1AE8925E"
                            BorderBrush="#52E8925E"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                       FontSize="14"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource StackrootWarnBrush}"
                                       Text="&#xE7BA;" />
                            <TextBlock FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource StackrootWarnBrush}"
                                       Text="{DynamicResource Loc.BackupSiteDialog.Preview.Archive.Warning}" />
                        </StackPanel>
                    </Border>

                    <!-- Files row -->
                    <Border Margin="0,0,0,4"
                            Padding="10,8"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="#E0526B"
                                       Text="×" />
                            <TextBlock FontSize="12"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Loc.BackupSiteDialog.Preview.Archive.Files}" />
                        </StackPanel>
                    </Border>

                    <!-- Databases row -->
                    <Border Margin="0,0,0,4"
                            Padding="10,8"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Visibility="{Binding HasDatabases, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="#E0526B"
                                       Text="×" />
                            <TextBlock FontSize="12"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Loc.BackupSiteDialog.Preview.Archive.Databases}" />
                        </StackPanel>
                    </Border>

                    <!-- Processes row -->
                    <Border Margin="0,0,0,4"
                            Padding="10,8"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Visibility="{Binding HasProcesses, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="#E0526B"
                                       Text="×" />
                            <TextBlock FontSize="12"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Loc.BackupSiteDialog.Preview.Archive.Processes}" />
                        </StackPanel>
                    </Border>

                    <!-- Tasks row -->
                    <Border Margin="0,0,0,4"
                            Padding="10,8"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Visibility="{Binding HasScheduledTasks, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="#E0526B"
                                       Text="×" />
                            <TextBlock FontSize="12"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Loc.BackupSiteDialog.Preview.Archive.Tasks}" />
                        </StackPanel>
                    </Border>

                    <!-- Site record row -->
                    <Border Padding="10,8"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="#E0526B"
                                       Text="×" />
                            <TextBlock FontSize="12"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Loc.BackupSiteDialog.Preview.Archive.SiteRecord}" />
                        </StackPanel>
                    </Border>

                </StackPanel>

            </StackPanel>
        </Grid>
    </Grid>
</Window>
