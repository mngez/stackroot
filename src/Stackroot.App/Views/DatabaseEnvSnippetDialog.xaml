<Window x:Class="Stackroot.App.Views.DatabaseEnvSnippetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:Stackroot.App.Windows"
        Title=".env snippet"
        Width="560"
        Height="420"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False"
        windows:WindowsTheme.EnableDarkTitleBar="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="{Binding DatabaseName, StringFormat=.env snippet for {0}}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Copy these lines into your site .env file."
                       TextWrapping="Wrap" />
        </StackPanel>

        <TextBox Grid.Row="1"
                 Margin="0,14,0,0"
                 Padding="12,10"
                 FontFamily="Consolas"
                 FontSize="12"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Text="{Binding Snippet, Mode=OneWay}" />

        <StackPanel Grid.Row="2"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button MinWidth="100"
                    Margin="0,0,8,0"
                    Content="Copy"
                    Style="{StaticResource StackrootPrimaryButtonStyle}"
                    Command="{Binding CopyCommand}" />
            <Button MinWidth="100"
                    Content="Close"
                    Command="{Binding CloseCommand}" />
        </StackPanel>
    </Grid>
</Window>
