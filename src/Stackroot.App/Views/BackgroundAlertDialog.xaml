<Window x:Class="Stackroot.App.Views.BackgroundAlertDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:Stackroot.App.Windows"
        Title="Stackroot"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False"
        windows:WindowsTheme.EnableDarkTitleBar="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Icon + Title + Message -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="IconBorder"
                    Grid.Column="0"
                    Width="44"
                    Height="44"
                    Margin="0,0,14,0"
                    VerticalAlignment="Top"
                    CornerRadius="22"
                    BorderThickness="1">
                <TextBlock x:Name="KindIcon"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource StackrootIconFont}"
                           FontSize="18" />
            </Border>

            <StackPanel Grid.Column="1">
                <TextBlock x:Name="TitleText"
                           FontSize="17"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="MessageText"
                           Margin="0,8,0,0"
                           FontSize="13"
                           LineHeight="20"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <!-- Detail block (path, extra info, or exception message) -->
        <Border x:Name="DetailBorder"
                Grid.Row="1"
                Margin="0,14,0,0"
                Padding="12,10"
                Background="{StaticResource StackrootCardBrush}"
                BorderBrush="{StaticResource StackrootBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
            <TextBlock x:Name="DetailText"
                       FontFamily="Consolas"
                       FontSize="11.5"
                       LineHeight="17"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Action buttons + Close -->
        <StackPanel x:Name="ButtonsPanel"
                    Grid.Row="3"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal" />
    </Grid>
</Window>
