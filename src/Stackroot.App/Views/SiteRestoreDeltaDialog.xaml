<Window x:Class="Stackroot.App.Views.SiteRestoreDeltaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:Stackroot.App.Windows"
        Title="{DynamicResource Loc.SiteRestoreDelta.Title}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="940"
        MinWidth="700"
        SizeToContent="Height"
        MaxHeight="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False"
        windows:WindowsTheme.EnableDarkTitleBar="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Left panel: interactive delta item (with Keep toggle for deletes, Include checkbox for restore/replace) -->
        <DataTemplate x:Key="DeltaItemTemplate">
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Per-item include checkbox (only for Restore/Replace database items) -->
                <CheckBox Grid.Column="0"
                          IsChecked="{Binding IsIncluded}"
                          VerticalAlignment="Center"
                          Visibility="{Binding CanToggleInclude, Converter={StaticResource BoolToVis}}" />
                <TextBlock Grid.Column="1"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Foreground="{Binding ActionBrush}"
                           Text="{Binding ActionBadge}" />
                <TextBlock Grid.Column="2"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Text="{Binding DisplayName}" />
                <!-- Delete items: Keep / Kept toggle -->
                <Grid Grid.Column="3"
                      Margin="10,0,0,0"
                      Visibility="{Binding IsDelete, Converter={StaticResource BoolToVis}}">
                    <Button Padding="8,3"
                            FontSize="11"
                            VerticalAlignment="Center"
                            Content="{DynamicResource Loc.SiteRestoreDelta.KeepButton}"
                            Command="{Binding ToggleKeepCommand}"
                            Visibility="{Binding WillDelete, Converter={StaticResource BoolToVis}}" />
                    <Button FontSize="11"
                            VerticalAlignment="Center"
                            Content="{DynamicResource Loc.SiteRestoreDelta.KeptLabel}"
                            Command="{Binding ToggleKeepCommand}"
                            Visibility="{Binding WillKeep, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </Grid>
        </DataTemplate>

        <!-- Right panel: summary item with colored action description -->
        <DataTemplate x:Key="SummaryItemTemplate">
            <Border Margin="0,2"
                    Padding="10,7"
                    CornerRadius="5"
                    Background="{StaticResource StackrootCardBrush}"
                    BorderBrush="{StaticResource StackrootBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Foreground="{Binding ActionBrush}"
                               Text="{Binding ActionBadge}" />
                    <TextBlock Grid.Column="1"
                               FontSize="12"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Text="{Binding DisplayName}" />
                    <TextBlock Grid.Column="2"
                               FontSize="11"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Action}" Value="Replace">
                                        <Setter Property="Text" Value="{DynamicResource Loc.SiteRestoreDelta.Summary.WillBeReplaced}" />
                                        <Setter Property="Foreground" Value="#91A0B5" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Action}" Value="Restore">
                                        <Setter Property="Text" Value="{DynamicResource Loc.SiteRestoreDelta.Summary.WillBeRestored}" />
                                        <Setter Property="Foreground" Value="#8FD6B6" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding WillDeleteFinal}" Value="True">
                                        <Setter Property="Text" Value="{DynamicResource Loc.SiteRestoreDelta.Summary.WillBeDeleted}" />
                                        <Setter Property="Foreground" Value="#E0526B" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding WillKeepFinal}" Value="True">
                                        <Setter Property="Text" Value="{DynamicResource Loc.SiteRestoreDelta.Summary.WillBeKept}" />
                                        <Setter Property="Foreground" Value="#8FD6B6" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="500" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── LEFT PANEL: restore options form ── -->
        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="{DynamicResource Loc.SiteRestoreDelta.Title}" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{Binding SiteDomain}" />
                </StackPanel>

                <!-- Backup info -->
                <Border Grid.Row="1"
                        Margin="0,14,0,0"
                        Padding="10,8"
                        Background="{StaticResource StackrootCardBrush}"
                        BorderBrush="{StaticResource StackrootBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                                       FontSize="12"
                                       Width="60"
                                       Text="{DynamicResource Loc.RestoreSiteDialog.BackupInfoLabel}" />
                            <TextBlock FontSize="12" Text="{Binding SiteName}" />
                        </StackPanel>
                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                                       FontSize="12"
                                       Width="60"
                                       Text="{DynamicResource Loc.RestoreSiteDialog.DateLabel}" />
                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                       Text="{Binding BackupDate}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Warning -->
                <Border Grid.Row="2"
                        Margin="0,10,0,0"
                        Padding="10,8"
                        Background="#1AE8925E"
                        BorderBrush="#52E8925E"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                   FontSize="13"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource StackrootWarnBrush}"
                                   Text="&#xE7BA;" />
                        <TextBlock FontSize="12"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource StackrootWarnBrush}"
                                   Text="{DynamicResource Loc.SiteRestoreDelta.Warning}" />
                    </StackPanel>
                </Border>

                <!-- Loading / error state -->
                <StackPanel Grid.Row="3"
                            Margin="0,20,0,0"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <ProgressBar IsIndeterminate="True"
                                 Height="3"
                                 Margin="0,0,0,14"
                                 Foreground="{StaticResource StackrootAccentBrush}"
                                 Background="Transparent"
                                 BorderThickness="0" />
                    <TextBlock FontSize="12"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{DynamicResource Loc.SiteRestoreDelta.Computing}" />
                </StackPanel>

                <Border Grid.Row="3"
                        Margin="0,20,0,0"
                        Padding="10,8"
                        Background="#1AE0526B"
                        BorderBrush="#52E0526B"
                        BorderThickness="1"
                        CornerRadius="6"
                        Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}">
                    <TextBlock FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="#E0526B"
                               Text="{Binding LoadError}" />
                </Border>

                <!-- Files section -->
                <StackPanel Grid.Row="4"
                            Margin="0,14,0,0"
                            Visibility="{Binding HasBackupFiles, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox IsChecked="{Binding RestoreFiles}" />
                        <TextBlock Margin="8,0,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Text="{DynamicResource Loc.SiteRestoreDelta.FilesSection}" />
                    </StackPanel>
                    <Border Padding="12,8"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="13"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="#91A0B5"
                                       Text="↺" />
                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Loc.SiteRestoreDelta.FilesWillBeReplaced}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Databases section -->
                <StackPanel Grid.Row="5"
                            Margin="0,14,0,0"
                            Visibility="{Binding ShowDatabasesSection, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox IsChecked="{Binding RestoreDatabases}"
                                  Visibility="{Binding HasBackupDatabases, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Margin="8,0,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Text="{DynamicResource Loc.SiteRestoreDelta.DatabasesSection}" />
                    </StackPanel>
                    <Border Padding="12,6"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <ItemsControl ItemsSource="{Binding DatabaseItems}"
                                      ItemTemplate="{StaticResource DeltaItemTemplate}" />
                    </Border>
                </StackPanel>

                <!-- Processes section -->
                <StackPanel Grid.Row="6"
                            Margin="0,14,0,0"
                            Visibility="{Binding ShowProcessesSection, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox IsChecked="{Binding RestoreProcesses}"
                                  Visibility="{Binding HasBackupProcesses, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Margin="8,0,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Text="{DynamicResource Loc.SiteRestoreDelta.ProcessesSection}" />
                    </StackPanel>
                    <Border Padding="12,6"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <ItemsControl ItemsSource="{Binding ProcessItems}"
                                      ItemTemplate="{StaticResource DeltaItemTemplate}" />
                    </Border>
                </StackPanel>

                <!-- Scheduled Tasks section -->
                <StackPanel Grid.Row="7"
                            Margin="0,14,0,0"
                            Visibility="{Binding ShowTasksSection, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox IsChecked="{Binding RestoreScheduledTasks}"
                                  Visibility="{Binding HasBackupScheduledTasks, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Margin="8,0,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Text="{DynamicResource Loc.SiteRestoreDelta.TasksSection}" />
                    </StackPanel>
                    <Border Padding="12,6"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <ItemsControl ItemsSource="{Binding TaskItems}"
                                      ItemTemplate="{StaticResource DeltaItemTemplate}" />
                    </Border>
                </StackPanel>

                <!-- Empty state -->
                <TextBlock Grid.Row="8"
                           Margin="0,14,0,0"
                           FontSize="12"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           TextWrapping="Wrap"
                           Visibility="{Binding ShowNothingToReport, Converter={StaticResource BoolToVis}}"
                           Text="{DynamicResource Loc.SiteRestoreDelta.NothingToReport}" />

                <!-- Buttons -->
                <StackPanel Grid.Row="9"
                            Margin="0,20,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <Button Width="88"
                            Margin="0,0,8,0"
                            Content="{DynamicResource Loc.Common.Cancel}"
                            Command="{Binding CancelCommand}" />
                    <Button Width="110"
                            Style="{StaticResource StackrootStopButtonStyle}"
                            Content="{DynamicResource Loc.SiteRestoreDelta.RestoreButton}"
                            Command="{Binding RestoreCommand}" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ── COLUMN SEPARATOR ── -->
        <Border Grid.Column="1"
                Background="{StaticResource StackrootBorderBrush}" />

        <!-- ── RIGHT PANEL: what will happen summary ── -->
        <Grid Grid.Column="2" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"
                       Text="{DynamicResource Loc.SiteRestoreDelta.Summary.Title}" />

            <!-- Loading placeholder -->
            <TextBlock Grid.Row="1"
                       VerticalAlignment="Top"
                       FontSize="12"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                       Text="{DynamicResource Loc.SiteRestoreDelta.Computing}" />

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <!-- Files summary line -->
                    <Border Margin="0,0,0,2"
                            Padding="10,7"
                            CornerRadius="5"
                            Visibility="{Binding RestoreFiles, Converter={StaticResource BoolToVis}}"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↺"
                                       FontSize="13"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="#91A0B5" />
                            <TextBlock FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="#91A0B5"
                                       Text="{DynamicResource Loc.SiteRestoreDelta.Summary.FilesLine}" />
                        </StackPanel>
                    </Border>
                    <CheckBox Margin="2,4,0,6"
                              FontSize="11"
                              IsChecked="{Binding SkipFileSafetyCopy}"
                              Visibility="{Binding ShowSkipFileSafetyCopy, Converter={StaticResource BoolToVis}}"
                              Content="{DynamicResource Loc.SiteRestoreDelta.SkipFileSafetyCopy}" />

                    <!-- Databases summary -->
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,12,0,4"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Visibility="{Binding ShowDatabasesSummary, Converter={StaticResource BoolToVis}}"
                               Text="{DynamicResource Loc.SiteRestoreDelta.DatabasesSection}" />
                    <ItemsControl ItemsSource="{Binding DatabaseSummaryItems}"
                                  Visibility="{Binding ShowDatabasesSummary, Converter={StaticResource BoolToVis}}"
                                  ItemTemplate="{StaticResource SummaryItemTemplate}" />
                    <CheckBox Margin="2,4,0,0"
                              FontSize="11"
                              IsChecked="{Binding SkipDbSafetyCopy}"
                              Visibility="{Binding ShowSkipDbSafetyCopy, Converter={StaticResource BoolToVis}}"
                              Content="{DynamicResource Loc.SiteRestoreDelta.SkipDbSafetyCopy}" />

                    <!-- Processes summary -->
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,12,0,4"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Visibility="{Binding ShowProcessesSection, Converter={StaticResource BoolToVis}}"
                               Text="{DynamicResource Loc.SiteRestoreDelta.ProcessesSection}" />
                    <ItemsControl ItemsSource="{Binding ProcessItems}"
                                  Visibility="{Binding ShowProcessesSection, Converter={StaticResource BoolToVis}}"
                                  ItemTemplate="{StaticResource SummaryItemTemplate}" />

                    <!-- Scheduled Tasks summary -->
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,12,0,4"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Visibility="{Binding ShowTasksSection, Converter={StaticResource BoolToVis}}"
                               Text="{DynamicResource Loc.SiteRestoreDelta.TasksSection}" />
                    <ItemsControl ItemsSource="{Binding TaskItems}"
                                  Visibility="{Binding ShowTasksSection, Converter={StaticResource BoolToVis}}"
                                  ItemTemplate="{StaticResource SummaryItemTemplate}" />

                    <!-- Nothing to report -->
                    <TextBlock Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               TextWrapping="Wrap"
                               Visibility="{Binding ShowNothingToReport, Converter={StaticResource BoolToVis}}"
                               Text="{DynamicResource Loc.SiteRestoreDelta.NothingToReport}" />

                    <!-- Disk space estimate -->
                    <Border Margin="0,14,0,0"
                            Padding="10,10"
                            Background="{StaticResource StackrootCardBrush}"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Visibility="{Binding HasSpaceEstimate, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,7"
                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                       Text="{DynamicResource Loc.SiteRestoreDelta.SpaceRequired}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           FontSize="12"
                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                           Text="{DynamicResource Loc.SiteRestoreDelta.SpaceExtraction}" />
                                <TextBlock Grid.Column="1"
                                           FontSize="12"
                                           Text="{Binding SpaceExtractionText}" />
                            </Grid>
                            <Grid Margin="0,3,0,0"
                                  Visibility="{Binding HasDbRollback, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           FontSize="12"
                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                           Text="{DynamicResource Loc.SiteRestoreDelta.SpaceRollback}" />
                                <TextBlock Grid.Column="1"
                                           FontSize="12"
                                           Text="{Binding SpaceRollbackText}" />
                            </Grid>
                            <Separator Margin="0,7,0,7"
                                       Background="{StaticResource StackrootBorderBrush}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                           Text="{DynamicResource Loc.SiteRestoreDelta.SpaceTotal}" />
                                <TextBlock Grid.Column="1"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="{Binding SpaceTotalText}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
