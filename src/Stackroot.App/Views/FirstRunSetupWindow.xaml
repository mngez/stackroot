<Window x:Class="Stackroot.App.Views.FirstRunSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Stackroot.App.ViewModels"
        Title="Stackroot Setup"
        Width="560"
        MinHeight="420"
        SizeToContent="Height"
        MaxHeight="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Text="{Binding Headline}" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="14"
                       LineHeight="20"
                       Text="{Binding Subheadline}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="2"
                Margin="0,22,0,0"
                Padding="14"
                Background="{StaticResource StackrootCardBrush}"
                BorderBrush="{StaticResource StackrootBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          MaxHeight="360">
                <ItemsControl ItemsSource="{Binding Steps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:StartupStepViewModel}">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Top"
                                           FontFamily="{StaticResource StackrootIconFont}"
                                           FontSize="14"
                                           Text="{Binding StatusGlyph}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource StackrootTextMutedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:StartupStepStatus.Running}">
                                                    <Setter Property="Foreground" Value="{StaticResource StackrootAccentTextBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:StartupStepStatus.Completed}">
                                                    <Setter Property="Foreground" Value="{StaticResource StackrootAccentTextBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:StartupStepStatus.Failed}">
                                                    <Setter Property="Foreground" Value="{StaticResource StackrootDangerTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <StackPanel Grid.Column="1">
                                    <TextBlock FontSize="14"
                                               FontWeight="Medium"
                                               Text="{Binding Title}" />
                                    <TextBlock Margin="0,2,0,0"
                                               Foreground="{StaticResource StackrootTextMutedBrush}"
                                               FontSize="12"
                                               Text="{Binding Detail}"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Detail}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Detail}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:StartupStepStatus.Failed}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3"
                    Margin="0,18,0,0">
            <ProgressBar Height="4"
                         IsIndeterminate="True"
                         BorderThickness="0"
                         Background="#121A26"
                         Foreground="{StaticResource StackrootAccentBrush}">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasFailed}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>

            <Button MinWidth="160"
                    Margin="0,14,0,0"
                    HorizontalAlignment="Right"
                    Content="Open Stackroot"
                    Command="{Binding OpenStackrootCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource StackrootPrimaryButtonStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowOpenButton}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
