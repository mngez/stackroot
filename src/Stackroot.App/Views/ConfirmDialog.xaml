<Window x:Class="Stackroot.App.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:Stackroot.App.Windows"
        Title="{Binding Title, FallbackValue=Confirm}"
        Width="420"
        MinWidth="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False"
        windows:WindowsTheme.EnableDarkTitleBar="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Text="{Binding Title}" />

        <TextBlock Grid.Row="1"
                   Margin="0,12,0,0"
                   Foreground="{StaticResource StackrootTextMutedBrush}"
                   Text="{Binding Message}"
                   TextWrapping="Wrap" />

        <CheckBox Grid.Row="2"
                  Margin="0,14,0,0"
                  IsChecked="{Binding IsChecked}"
                  Foreground="{StaticResource StackrootTextMutedBrush}"
                  Content="{Binding CheckboxLabel}"
                  Visibility="{Binding ShowCheckbox, Converter={StaticResource BoolToVis}}" />

        <StackPanel Grid.Row="3"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="88"
                    Margin="0,0,8,0"
                    Content="Cancel"
                    Command="{Binding CancelCommand}" />
            <Button Width="100"
                    Content="{Binding ConfirmText}"
                    Command="{Binding ConfirmCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource StackrootPrimaryButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDanger}" Value="True">
                                <Setter Property="Background" Value="#1AE88A92" />
                                <Setter Property="BorderBrush" Value="#52E88A92" />
                                <Setter Property="Foreground" Value="{StaticResource StackrootDangerTextBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
