<Window x:Class="Stackroot.App.Views.PackageVersionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title, FallbackValue=Package versions}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="520"
        MinWidth="460"
        SizeToContent="Height"
        MaxHeight="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{Binding Hint}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1"
                BorderBrush="{StaticResource StackrootBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0">
            <Grid>
                <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{DynamicResource Loc.PackageVersions.NoVersions}"
                           Visibility="{Binding ShowEmptyCatalog, Converter={StaticResource BoolToVis}}" />

                <ListBox ItemsSource="{Binding Versions}"
                         SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         MaxHeight="360"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Visibility="{Binding HasVersions, Converter={StaticResource BoolToVis}}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Label}" />
                                    <Border Margin="10,0,0,0"
                                            Padding="6,2"
                                            VerticalAlignment="Center"
                                            Background="#223047"
                                            CornerRadius="4"
                                            Visibility="{Binding ShowInstalledBadge, Converter={StaticResource BoolToVis}}">
                                        <TextBlock FontSize="11"
                                                   Foreground="{StaticResource StackrootAccentTextBrush}"
                                                   Text="{DynamicResource Loc.PackageVersions.Installed}" />
                                    </Border>
                                    <Border Margin="10,0,0,0"
                                            Padding="6,2"
                                            VerticalAlignment="Center"
                                            Background="#1A3D2E"
                                            CornerRadius="4"
                                            Visibility="{Binding ShowActiveBadge, Converter={StaticResource BoolToVis}}">
                                        <TextBlock FontSize="11"
                                                   Foreground="#8FD6B6"
                                                   Text="{DynamicResource Loc.PackageVersions.Active}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource StackrootTextMutedBrush}"
                                           FontSize="12"
                                           Text="{Binding Description}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding ShowDescription, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Margin="0,0,8,0"
                    MinWidth="88"
                    Content="{DynamicResource Loc.Common.Cancel}"
                    Command="{Binding CloseCommand}"
                    Style="{StaticResource StackrootStopButtonStyle}" />

            <Button Grid.Column="2"
                    MinWidth="112"
                    Command="{Binding PrimaryActionCommand}"
                    Content="{Binding PrimaryActionLabel}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource StackrootStopButtonStyle}">
                        <Setter Property="Background" Value="{StaticResource StackrootAccentBrush}" />
                        <Setter Property="BorderBrush" Value="#3A9070" />
                        <Setter Property="Foreground" Value="#062113" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPrimaryActionDanger}" Value="True">
                                <Setter Property="Background" Value="#1AE88A92" />
                                <Setter Property="BorderBrush" Value="#52E88A92" />
                                <Setter Property="Foreground" Value="{StaticResource StackrootDangerTextBrush}" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>
