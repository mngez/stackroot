<Window x:Class="Stackroot.App.Views.SiteProcessLogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title, FallbackValue=Log}"
        Width="820"
        MinWidth="560"
        Height="560"
        MinHeight="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="{Binding Title, FallbackValue=Log}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{Binding ProcessName}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ProcessName}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button Margin="0,0,10,0"
                        Padding="10,6"
                        VerticalAlignment="Center"
                        Content="Run again"
                        ToolTip="Run this command again"
                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                        Command="{Binding RunAgainCommand}"
                        Visibility="{Binding ShowRunAgainButton, Converter={StaticResource BoolToVis}}" />
                <TextBlock Margin="0,0,10,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource StackrootAccentTextBrush}"
                           Text="{Binding RunningLabel}" />
                <TextBlock Margin="0,0,10,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{Binding PidLabel}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                Padding="10"
                Background="#1E1E1E"
                BorderBrush="{StaticResource StackrootBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Margin="0,0,0,8"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="#9DA5B4"
                           Text="{Binding LogHeaderLine}"
                           TextWrapping="Wrap"
                           Visibility="{Binding ShowLogHeader, Converter={StaticResource BoolToVis}}" />

                <RichTextBox x:Name="LogViewer"
                             Grid.Row="1"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="12"
                             Foreground="#D4D4D4"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />

                <TextBlock Grid.Row="2"
                           Margin="0,8,0,0"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="#9DA5B4"
                           Text="{Binding LogFooterLine}"
                           TextWrapping="Wrap"
                           Visibility="{Binding ShowLogFooter, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="0,8,0,0"
                   Foreground="{StaticResource StackrootDangerBrush}"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap" />

        <DockPanel Grid.Row="3" Margin="0,12,0,0" LastChildFill="False">
            <CheckBox DockPanel.Dock="Left"
                      VerticalAlignment="Center"
                      Content="Live updates"
                      IsChecked="{Binding LiveUpdates}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Width="100"
                        Margin="0,0,8,0"
                        Content="{Binding CancelButtonLabel}"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding CanCancelCommand}"
                        Visibility="{Binding ShowCancelButton, Converter={StaticResource BoolToVis}}" />
                <Button Width="88"
                        Margin="0,0,8,0"
                        Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        Visibility="{Binding ShowRefreshButton, Converter={StaticResource BoolToVis}}" />
                <Button Width="88"
                        Content="Close"
                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                        Command="{Binding CloseCommand}"
                        Click="OnCloseClick" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
