<Window x:Class="Stackroot.App.Views.CronTaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:Stackroot.App.Windows"
        Title="Scheduled Task"
        Width="560" Height="530"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False"
        windows:WindowsTheme.EnableDarkTitleBar="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Text="New Scheduled Task" />

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <!-- Label -->
            <TextBlock FontSize="12" Foreground="{StaticResource StackrootTextMutedBrush}" Text="Label" />
            <TextBox Margin="0,4,0,12" Padding="10,6" MinHeight="32"
                     Text="{Binding TaskLabel, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Command -->
            <TextBlock FontSize="12" Foreground="{StaticResource StackrootTextMutedBrush}" Text="Command" />
            <TextBox Margin="0,4,0,12" Padding="10,6" MinHeight="32" FontFamily="Consolas"
                     Text="{Binding TaskCommand, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Working Directory -->
            <TextBlock FontSize="12" Foreground="{StaticResource StackrootTextMutedBrush}" Text="Working directory" />
            <DockPanel Margin="0,4,0,14">
                <Button DockPanel.Dock="Right" Width="36" Height="32" Padding="0"
                        Margin="4,0,0,0" Content="…"
                        Command="{Binding BrowseDirCommand}" />
                <TextBox Padding="10,6" MinHeight="32" FontFamily="Consolas"
                         Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>

            <!-- Cron fields -->
            <TextBlock FontSize="12" Foreground="{StaticResource StackrootTextMutedBrush}" Text="Schedule" />
            <Grid Margin="0,4,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                    <TextBlock FontSize="11" Foreground="{StaticResource StackrootTextMutedBrush}" Text="Minute" />
                    <ComboBox Margin="0,2,0,0" Padding="6,4" FontSize="13" MinHeight="30"
                              ItemsSource="{Binding MinuteOptions}"
                              DisplayMemberPath="Label"
                              SelectedItem="{Binding SelectedMinute}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,4,0">
                    <TextBlock FontSize="11" Foreground="{StaticResource StackrootTextMutedBrush}" Text="Hour" />
                    <ComboBox Margin="0,2,0,0" Padding="6,4" FontSize="13" MinHeight="30"
                              ItemsSource="{Binding HourOptions}"
                              DisplayMemberPath="Label"
                              SelectedItem="{Binding SelectedHour}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,4,0">
                    <TextBlock FontSize="11" Foreground="{StaticResource StackrootTextMutedBrush}" Text="Day" />
                    <ComboBox Margin="0,2,0,0" Padding="6,4" FontSize="13" MinHeight="30"
                              ItemsSource="{Binding DayOptions}"
                              DisplayMemberPath="Label"
                              SelectedItem="{Binding SelectedDay}" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="0,0,4,0">
                    <TextBlock FontSize="11" Foreground="{StaticResource StackrootTextMutedBrush}" Text="Month" />
                    <ComboBox Margin="0,2,0,0" Padding="6,4" FontSize="13" MinHeight="30"
                              ItemsSource="{Binding MonthOptions}"
                              DisplayMemberPath="Label"
                              SelectedItem="{Binding SelectedMonth}" />
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock FontSize="11" Foreground="{StaticResource StackrootTextMutedBrush}" Text="Weekday" />
                    <ComboBox Margin="0,2,0,0" Padding="6,4" FontSize="13" MinHeight="30"
                              ItemsSource="{Binding WeekdayOptions}"
                              DisplayMemberPath="Label"
                              SelectedItem="{Binding SelectedWeekday}" />
                </StackPanel>
            </Grid>

            <!-- Cron preview / manual edit -->
            <Border Padding="8,6" Background="#121A26"
                    BorderBrush="{StaticResource StackrootBorderBrush}"
                    BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" FontSize="12"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{Binding CronPreview, StringFormat=— {0}}" />
                    <TextBox Padding="4,2" FontFamily="Consolas" FontSize="13"
                             BorderThickness="0" Background="Transparent"
                             Foreground="{StaticResource StackrootAccentTextBrush}"
                             Text="{Binding CronExpression, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
            </Border>
            <TextBlock Margin="0,4,0,0" FontSize="11"
                       Foreground="{StaticResource StackrootWarnBrush}"
                       Text="{Binding CronError}" />

            <!-- Capture log -->
            <CheckBox Margin="0,14,0,0" Content="Capture output to log file" IsChecked="{Binding CaptureLog}" />
        </StackPanel>

        <DockPanel Grid.Row="2" Margin="0,14,0,0" LastChildFill="False">
            <Button DockPanel.Dock="Right" MinWidth="90" Padding="10,6"
                    Style="{StaticResource StackrootPrimaryButtonStyle}"
                    Content="Save" Command="{Binding SaveCommand}" />
            <Button DockPanel.Dock="Right" MinWidth="80" Padding="10,6" Margin="0,0,8,0"
                    Content="Cancel" Command="{Binding CancelCommand}" />
        </DockPanel>
    </Grid>
</Window>
