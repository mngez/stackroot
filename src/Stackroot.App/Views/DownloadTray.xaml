<UserControl x:Class="Stackroot.App.Views.DownloadTray"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Width="36" Height="36">
        <Button x:Name="TrayButton"
                Width="36"
                Height="36"
                Padding="0"
                Style="{StaticResource StackrootIconButtonStyle}"
                ToolTip="{DynamicResource Loc.Downloads.Title}"
                Command="{Binding ToggleCommand}"
                PreviewMouseLeftButtonDown="TrayButton_PreviewMouseLeftButtonDown">
            <Grid>
                <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                           FontSize="14"
                           Text="&#xE896;" />
                <Border MinWidth="16"
                        Height="16"
                        Padding="4,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-5,-5,0"
                        Background="{StaticResource StackrootAccentBrush}"
                        CornerRadius="8"
                        Visibility="{Binding ShowBadge, Converter={StaticResource BoolToVis}}">
                    <TextBlock FontSize="10"
                               FontWeight="Bold"
                               Foreground="#062113"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="{Binding ActiveCount}" />
                </Border>
            </Grid>
        </Button>

        <Popup x:Name="TrayPopup"
               PlacementTarget="{Binding ElementName=TrayButton}"
               Placement="Bottom"
               HorizontalOffset="-324"
               VerticalOffset="8"
               StaysOpen="False"
               AllowsTransparency="True"
               IsOpen="{Binding IsOpen, Mode=TwoWay}">
            <Border Width="360"
                    Padding="0"
                    Background="{StaticResource StackrootCardBrush}"
                    BorderBrush="{StaticResource StackrootBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="4"
                                      Opacity="0.45"
                                      Color="Black" />
                </Border.Effect>
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top"
                               Margin="12,10,12,8"
                               LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                VerticalAlignment="Center"
                                Style="{StaticResource StackrootTrayHeaderIconButtonStyle}"
                                ToolTip="{DynamicResource Loc.Common.Close}"
                                Command="{Binding CloseCommand}">
                            <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                                       FontSize="10"
                                       Text="&#xE711;" />
                        </Button>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Loc.Downloads.Title}" />
                            <TextBlock Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                       FontSize="11"
                                       Text="{DynamicResource Loc.Downloads.RunInBackground}" />
                        </StackPanel>
                    </DockPanel>

                    <Border DockPanel.Dock="Top"
                            BorderBrush="{StaticResource StackrootBorderBrush}"
                            BorderThickness="0,1,0,0" />

                    <TextBlock DockPanel.Dock="Top"
                               Margin="12,12"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="{DynamicResource Loc.Downloads.NoActive}"
                               Visibility="{Binding ShowEmptyPanel, Converter={StaticResource BoolToVis}}" />

                    <ScrollViewer MaxHeight="320"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10"
                                            BorderBrush="{StaticResource StackrootBorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding DisplayName}"
                                                           TextWrapping="Wrap" />
                                                <StackPanel DockPanel.Dock="Right"
                                                            Orientation="Horizontal">
                                                    <TextBlock Margin="0,0,8,0"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               Foreground="{Binding PhaseColor}"
                                                               Text="{Binding PhaseLabel}" />
                                                    <Button Width="56"
                                                            Height="24"
                                                            Padding="4,0"
                                                            FontSize="11"
                                                            Content="{DynamicResource Loc.Common.Cancel}"
                                                            Command="{Binding CancelCommand}"
                                                            Visibility="{Binding ShowCancel, Converter={StaticResource BoolToVis}}" />
                                                </StackPanel>
                                            </DockPanel>

                                            <ProgressBar Margin="0,8,0,0"
                                                         Height="5"
                                                         Maximum="100"
                                                         Value="{Binding Percent, Mode=OneWay}"
                                                         Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}" />

                                            <TextBlock Margin="0,6,0,0"
                                                       FontSize="12"
                                                       Foreground="{StaticResource StackrootTextMutedBrush}"
                                                       Text="{Binding Message}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
