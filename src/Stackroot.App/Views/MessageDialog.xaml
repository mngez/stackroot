<Window x:Class="Stackroot.App.Views.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Stackroot.App.ViewModels"
        xmlns:windows="clr-namespace:Stackroot.App.Windows"
        Title="{Binding Title, FallbackValue=Message}"
        Width="480"
        MinWidth="400"
        MaxWidth="560"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False"
        windows:WindowsTheme.EnableDarkTitleBar="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="44"
                    Height="44"
                    Margin="0,0,14,0"
                    VerticalAlignment="Top"
                    CornerRadius="22"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#1A4CAE8C" />
                        <Setter Property="BorderBrush" Value="#524CAE8C" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:StackrootDialogKind.Error}">
                                <Setter Property="Background" Value="#1AE88A92" />
                                <Setter Property="BorderBrush" Value="#52E88A92" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:StackrootDialogKind.Warning}">
                                <Setter Property="Background" Value="#1AE9BD5B" />
                                <Setter Property="BorderBrush" Value="#52E9BD5B" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:StackrootDialogKind.Question}">
                                <Setter Property="Background" Value="#1A91A0B5" />
                                <Setter Property="BorderBrush" Value="#5291A0B5" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource StackrootIconFont}"
                           FontSize="18"
                           Text="{Binding IconGlyph, Mode=OneWay}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource StackrootAccentTextBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:StackrootDialogKind.Error}">
                                    <Setter Property="Foreground" Value="{StaticResource StackrootDangerTextBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:StackrootDialogKind.Warning}">
                                    <Setter Property="Foreground" Value="{StaticResource StackrootWarnBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:StackrootDialogKind.Question}">
                                    <Setter Property="Foreground" Value="{StaticResource StackrootTextMutedBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <StackPanel Grid.Column="1">
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="{Binding Title}"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           FontSize="14"
                           LineHeight="20"
                           Text="{Binding Message}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,14,0,0"
                Padding="12,10"
                Background="{StaticResource StackrootCardBrush}"
                BorderBrush="{StaticResource StackrootBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Details}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Details}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock FontFamily="Consolas"
                       FontSize="11.5"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       LineHeight="17"
                       Text="{Binding Details}"
                       TextWrapping="Wrap" />
        </Border>

        <StackPanel Grid.Row="2"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="88"
                    Margin="0,0,8,0"
                    Content="{Binding CancelText}"
                    Command="{Binding CancelCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource StackrootButtonStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Buttons}" Value="{x:Static vm:StackrootDialogButtons.YesNoCancel}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Width="100"
                    Margin="0,0,8,0"
                    Content="{Binding NoText}"
                    Command="{Binding NoCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource StackrootButtonStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Buttons}" Value="{x:Static vm:StackrootDialogButtons.YesNo}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Buttons}" Value="{x:Static vm:StackrootDialogButtons.YesNoCancel}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Width="100"
                    Margin="0,0,8,0"
                    Content="{Binding YesText}"
                    Command="{Binding YesCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource StackrootPrimaryButtonStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Buttons}" Value="{x:Static vm:StackrootDialogButtons.YesNo}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Buttons}" Value="{x:Static vm:StackrootDialogButtons.YesNoCancel}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:StackrootDialogKind.Warning}">
                                <Setter Property="Background" Value="#1AE9BD5B" />
                                <Setter Property="BorderBrush" Value="#52E9BD5B" />
                                <Setter Property="Foreground" Value="{StaticResource StackrootWarnBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button MinWidth="100"
                    Content="{Binding OkText}"
                    Command="{Binding OkCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource StackrootPrimaryButtonStyle}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Buttons}" Value="{x:Static vm:StackrootDialogButtons.YesNo}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Buttons}" Value="{x:Static vm:StackrootDialogButtons.YesNoCancel}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:StackrootDialogKind.Error}">
                                <Setter Property="Background" Value="#1AE88A92" />
                                <Setter Property="BorderBrush" Value="#52E88A92" />
                                <Setter Property="Foreground" Value="{StaticResource StackrootDangerTextBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
