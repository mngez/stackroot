<Window x:Class="Stackroot.App.Views.BackupStartedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:Stackroot.App.Windows"
        Title="{DynamicResource Loc.BackupSiteDialog.Title}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="380"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False"
        windows:WindowsTheme.EnableDarkTitleBar="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Icon + title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock FontFamily="{StaticResource StackrootIconFont}"
                       FontSize="20"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Foreground="{StaticResource StackrootAccentBrush}"
                       Text="&#xE895;" />
            <TextBlock FontSize="17"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Text="{DynamicResource Loc.BackupSiteDialog.Title}" />
        </StackPanel>

        <!-- Message -->
        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock x:Name="MessageText"
                       FontSize="13"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       TextWrapping="Wrap"
                       LineHeight="20" />
        </StackPanel>

        <!-- OK button -->
        <StackPanel Grid.Row="2"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Right">
            <Button Width="80"
                    Style="{StaticResource StackrootPrimaryButtonStyle}"
                    Content="{DynamicResource Loc.Common.Close}"
                    Click="OnOk" />
        </StackPanel>
    </Grid>
</Window>
