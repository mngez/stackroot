<Window x:Class="Stackroot.App.Views.AddSiteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Stackroot.App.Helpers"
        Title="{DynamicResource Loc.AddSite.Title}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="560"
        MinWidth="520"
        SizeToContent="Height"
        MaxHeight="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="{DynamicResource Loc.AddSite.Title}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{DynamicResource Loc.AddSite.Subtitle}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      Margin="0,16,0,0"
                      MaxHeight="560"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="10"
                        Background="#1AE9BD5B"
                        BorderBrush="#52E9BD5B"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Foreground="{StaticResource StackrootWarnBrush}"
                               Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap" />
                </Border>

                <TextBlock Margin="0,12,0,8"
                           FontWeight="SemiBold"
                           Text="{DynamicResource Loc.AddSite.Template}" />
                <ItemsControl ItemsSource="{Binding TemplateCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,8,8"
                                    Padding="10"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding SelectCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource StackrootButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource StackrootAccentBrush}" />
                                                <Setter Property="Background" Value="#223047" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource StackrootTextMutedBrush}"
                                               Text="{Binding DocumentRoot, StringFormat=doc root: {0}}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="0,8,0,6"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{DynamicResource Loc.AddSite.SiteName}" />
                <TextBox Padding="10,6"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,12,0,6"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{DynamicResource Loc.AddSite.DomainName}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Padding="10,6"
                             FlowDirection="LeftToRight"
                             ToolTip="{DynamicResource Loc.AddSite.SubdomainTooltip}"
                             Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Column="1"
                               Margin="8,0"
                               VerticalAlignment="Center"
                               Text="." />
                    <TextBox Grid.Column="2"
                             Padding="10,6"
                             FlowDirection="LeftToRight"
                             Text="{Binding DomainSuffix, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <TextBlock Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{Binding PreviewDomain, StringFormat=→ {0}}" />

                <TextBlock Margin="0,12,0,6"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{DynamicResource Loc.AddSite.DomainAliases}" />
                <TextBox MinHeight="72"
                         Padding="10,6"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FlowDirection="LeftToRight"
                         Text="{Binding DomainAliasesText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{DynamicResource Loc.AddSite.AliasesHint}"
                           TextWrapping="Wrap" />

                <TextBlock Margin="0,12,0,6"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{DynamicResource Loc.AddSite.PhpBackend}" />
                <ComboBox Padding="8,4"
                          ItemsSource="{Binding PhpVersions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedPhpVersionId}"
                          IsEnabled="{Binding PhpSelectorEnabled}" />

                <TextBlock Margin="0,12,0,6"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{DynamicResource Loc.AddSite.NodeJs}" />
                <ComboBox Padding="8,4"
                          ItemsSource="{Binding NodeVersions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedNodeVersionId}" />

                <TextBlock Margin="0,12,0,6"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{DynamicResource Loc.AddSite.DocumentRoot}" />
                <TextBlock FontFamily="Consolas"
                           Text="{Binding DocumentRootLabel}" />
                <TextBlock Margin="0,2,0,0"
                           FontSize="12"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{DynamicResource Loc.AddSite.SetByTemplate}" />

                <TextBlock Margin="0,16,0,8"
                           FontWeight="SemiBold"
                           Text="{DynamicResource Loc.AddSite.Folder}" />
                <RadioButton Margin="0,0,0,6"
                             Content="{DynamicResource Loc.AddSite.CreateUnderWww}"
                             GroupName="SitePathMode"
                             IsChecked="{Binding IsDefaultPathMode}" />
                <RadioButton Margin="0,0,0,8"
                             Content="{DynamicResource Loc.AddSite.ExistingFolder}"
                             GroupName="SitePathMode"
                             IsChecked="{Binding IsCustomPathMode}" />
                <TextBlock Margin="0,0,0,8"
                           FontFamily="Consolas"
                           Text="{Binding PathPreview}"
                           TextWrapping="Wrap" />
                <Grid Visibility="{Binding IsCustomPathMode, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Padding="10,6"
                             FlowDirection="LeftToRight"
                             Text="{Binding CustomPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Margin="8,0,0,0"
                            Padding="12,6"
                            Command="{Binding BrowseFolderCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="16"
                                   Height="16"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center"
                                   Source="{x:Static helpers:StackrootImages.FolderIcon}"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock VerticalAlignment="Center"
                                       Text="{DynamicResource Loc.Common.Browse}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,18,0,0" LastChildFill="False">
            <CheckBox VerticalAlignment="Center"
                      IsChecked="{Binding GoToSiteDashboard}"
                      Foreground="{StaticResource StackrootTextMutedBrush}"
                      Content="{DynamicResource Loc.AddSite.GoToDashboard}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Width="88"
                        Margin="0,0,8,0"
                        Content="{DynamicResource Loc.Common.Cancel}"
                        Command="{Binding CloseCommand}" />
                <Button Width="100"
                        Content="{Binding CreateButtonText}"
                        Command="{Binding CreateCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource StackrootPrimaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCreating}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                    <Setter Property="Opacity" Value="0.6" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
