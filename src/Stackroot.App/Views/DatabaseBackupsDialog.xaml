<Window x:Class="Stackroot.App.Views.DatabaseBackupsDialog"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:windows="clr-namespace:Stackroot.App.Windows"

        Title="{Binding Title}"

        Width="720"

        Height="480"

        MinWidth="560"

        MinHeight="360"

        WindowStartupLocation="CenterOwner"

        Background="{StaticResource StackrootWindowBrush}"

        Foreground="{StaticResource StackrootTextBrush}"

        ShowInTaskbar="False"

        windows:WindowsTheme.EnableDarkTitleBar="True">

    <Grid Margin="20">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="*" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <StackPanel Grid.Row="0">

            <TextBlock FontSize="18"

                       FontWeight="SemiBold"

                       Text="{Binding Title}" />

            <TextBlock Margin="0,6,0,0"

                       Foreground="{StaticResource StackrootTextMutedBrush}"

                       Text="Select a backup file and restore it into the matching database."

                       TextWrapping="Wrap" />

        </StackPanel>



        <Border Grid.Row="1"

                Margin="0,14,0,0"

                Padding="12,10"

                Background="#182232"

                BorderBrush="#4CAE8C"

                BorderThickness="1"

                CornerRadius="8">

            <TextBlock FontWeight="SemiBold"

                       Text="{Binding SelectionSummary}"

                       TextWrapping="Wrap" />

        </Border>



        <DataGrid Grid.Row="2"
                  Margin="0,10,0,0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  AlternationCount="2"
                  AlternatingRowBackground="#131D2A"
                  RowBackground="Transparent"
                  ItemsSource="{Binding Backups}"
                  SelectedItem="{Binding SelectedBackup, Mode=TwoWay}">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="MinHeight" Value="40" />
                    <Setter Property="BorderBrush" Value="#1E324A" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="Foreground" Value="{StaticResource StackrootTextBrush}" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1A2A3D" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#223047" />
                            <Setter Property="BorderBrush" Value="#4CAE8C" />
                            <Setter Property="BorderThickness" Value="3,1,0,1" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="2*" />
                <DataGridTextColumn Header="Database" Binding="{Binding DatabaseLabel}" Width="*" />
                <DataGridTextColumn Header="Engine" Binding="{Binding EngineLabel}" Width="0.8*" />
                <DataGridTextColumn Header="Created" Binding="{Binding CreatedLabel}" Width="1.2*" />
                <DataGridTextColumn Header="Size" Binding="{Binding SizeLabel}" Width="0.8*" />
                <DataGridTemplateColumn Header="" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Delete"
                                    Padding="6,2"
                                    MinHeight="26"
                                    Style="{StaticResource StackrootStopButtonStyle}"
                                    Command="{Binding DataContext.DeleteBackupCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

        </DataGrid>



        <TextBlock Grid.Row="3"

                   Margin="0,10,0,0"

                   Foreground="{StaticResource StackrootTextMutedBrush}"

                   Text="{Binding StatusMessage}"

                   TextWrapping="Wrap" />



        <DockPanel Grid.Row="4"

                   Margin="0,14,0,0"

                   LastChildFill="False">

            <Button DockPanel.Dock="Left"

                    MinWidth="110"

                    Content="Open folder"

                    Command="{Binding OpenFolderCommand}" />

            <Button DockPanel.Dock="Left"

                    MinWidth="88"

                    Margin="8,0,0,0"

                    Content="Refresh"

                    Command="{Binding RefreshCommand}" />

            <StackPanel DockPanel.Dock="Right"

                        Orientation="Horizontal">

                <Button MinWidth="100"

                        Margin="0,0,8,0"

                        Content="Close"

                        Command="{Binding CloseCommand}" />

                <Button MinWidth="100"

                        Content="Restore"

                        Style="{StaticResource StackrootPrimaryButtonStyle}"

                        Command="{Binding RestoreCommand}" />

            </StackPanel>

        </DockPanel>

    </Grid>

</Window>
