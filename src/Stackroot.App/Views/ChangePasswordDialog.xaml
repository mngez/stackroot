<Window x:Class="Stackroot.App.Views.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Loc.ChangePassword.Title}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="400" MinWidth="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="16" FontWeight="SemiBold"
                   Text="{DynamicResource Loc.ChangePassword.Title}" />
        <TextBlock Grid.Row="0" Margin="0,28,0,0" Foreground="{StaticResource StackrootTextMutedBrush}"
                   Text="{DynamicResource Loc.ChangePassword.Subtitle}" />

        <PasswordBox Grid.Row="1" x:Name="PasswordInput"
                     Margin="0,12,0,0" Padding="10,8"
                     FontFamily="Consolas" FontSize="14" />

        <DockPanel Grid.Row="2" Margin="0,18,0,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Width="88" Margin="0,0,8,0"
                        Content="{DynamicResource Loc.Common.Cancel}"
                        Click="Cancel_Click" />
                <Button Width="100"
                        Content="{DynamicResource Loc.ChangePassword.Change}"
                        Style="{StaticResource StackrootPrimaryButtonStyle}"
                        Click="Change_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
