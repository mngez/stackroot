<Window x:Class="Stackroot.App.Views.AddGlobalProcessDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title, FallbackValue=Process}"
        Width="560"
        MinWidth="480"
        SizeToContent="Height"
        MaxHeight="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Text="{Binding Title}" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Configure a supervised background process."
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}" Text="Name" />
                <TextBox Margin="0,6,0,0"
                         Padding="10,6"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Linked site (optional)" />
                <ComboBox Margin="0,6,0,0"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SiteId}"
                          ItemsSource="{Binding Sites}" />

                <StackPanel Margin="0,12,0,0"
                            Visibility="{Binding ShowProjectFolder, Converter={StaticResource BoolToVis}}">
                    <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="Project folder" />
                    <TextBox Margin="0,6,0,0"
                             Padding="10,6"
                             Text="{Binding WorkDir, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               FontSize="12"
                               Text="Absolute project root when no site is linked."
                               TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Working directory" />
                <TextBox Margin="0,6,0,0"
                         Padding="10,6"
                         Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           FontSize="12"
                           Text="Relative to the project folder (. or game), or an absolute path that overrides it."
                           TextWrapping="Wrap" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Runtime" />
                <ComboBox Margin="0,6,0,0"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Runtime"
                          SelectedValue="{Binding Runtime}"
                          ItemsSource="{Binding RuntimeOptions}" />

                <StackPanel Margin="0,12,0,0"
                            Visibility="{Binding ShowPhpVersionPicker, Converter={StaticResource BoolToVis}}">
                    <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                               Text="PHP version" />
                    <ComboBox Margin="0,6,0,0"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedPhpVersionId}"
                              ItemsSource="{Binding PhpVersions}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource StackrootTextMutedBrush}"
                               FontSize="12"
                               Text="Used for PHP and Composer runtimes. Defaults to the linked site's PHP version."
                               TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Command" />
                <TextBox Margin="0,6,0,0"
                         Padding="10,6"
                         Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           FontSize="12"
                           Text="Shell: full command. Other runtimes: arguments after the executable."
                           TextWrapping="Wrap" />

                <CheckBox Margin="0,14,0,0"
                          Content="Enabled"
                          IsChecked="{Binding Enabled}" />
                <CheckBox Margin="0,8,0,0"
                          Content="Auto-start with Stackroot"
                          IsChecked="{Binding AutoStart}" />
                <CheckBox Margin="0,8,0,0"
                          Content="Featured (pin to top)"
                          IsChecked="{Binding Featured}" />
            </StackPanel>

            <DockPanel Grid.Row="2" Margin="0,18,0,0" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="88"
                            Margin="0,0,8,0"
                            Content="Cancel"
                            Command="{Binding CloseCommand}" />
                    <Button Width="100"
                            Content="Save"
                            Style="{StaticResource StackrootPrimaryButtonStyle}"
                            Command="{Binding SaveCommand}" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </ScrollViewer>
</Window>
