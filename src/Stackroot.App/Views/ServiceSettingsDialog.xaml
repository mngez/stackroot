<Window x:Class="Stackroot.App.Views.ServiceSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title, FallbackValue=Service settings}"
        Width="460"
        MinWidth="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="20" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Enable the service, choose auto-start, and configure network settings."
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <CheckBox Content="Enabled"
                      IsChecked="{Binding Enabled}" />
            <CheckBox Margin="0,10,0,0"
                      Content="Start automatically with Stackroot"
                      IsChecked="{Binding AutoStart}" />
            <CheckBox Margin="0,10,0,0"
                      Content="Auto-restart if it stops (keep alive)"
                      IsChecked="{Binding Supervise}" />

            <TextBlock Margin="0,16,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="Active package version" />
            <TextBlock Margin="0,4,0,0"
                       FontWeight="SemiBold"
                       Text="{Binding ActivePackageLabel}" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       Text="Change the active version from the package versions button on the Services page."
                       TextWrapping="Wrap" />

            <StackPanel Margin="0,16,0,0"
                        Visibility="{Binding ShowNetworkFields, Converter={StaticResource BoolToVis}}">
                <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}" Text="Host" />
                <TextBox Margin="0,6,0,0"
                         Padding="10,6"
                         Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="Port" />
                <TextBox Margin="0,6,0,0"
                         Padding="10,6"
                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Margin="0,12,0,0"
                        Visibility="{Binding ShowSslFields, Converter={StaticResource BoolToVis}}">
                <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}" Text="SSL port" />
                <TextBox Margin="0,6,0,0"
                         Padding="10,6"
                         Text="{Binding SslPort, UpdateSourceTrigger=PropertyChanged}" />
                <CheckBox Margin="0,10,0,0"
                          Content="Enable HTTPS (SSL)"
                          IsChecked="{Binding SslEnabled}" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       MinHeight="16"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
            <DockPanel Margin="0,12,0,0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="88"
                            Margin="0,0,8,0"
                            Content="Close"
                            Command="{Binding CloseCommand}" />
                    <Button Width="88"
                            Content="Save"
                            Style="{StaticResource StackrootPrimaryButtonStyle}"
                            Command="{Binding SaveCommand}" />
                </StackPanel>
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
