<Window x:Class="Stackroot.App.Views.ServiceSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title, FallbackValue=Service settings}"
        FlowDirection="{DynamicResource Loc.FlowDirection}"
        Width="460"
        MinWidth="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource StackrootWindowBrush}"
        Foreground="{StaticResource StackrootTextBrush}"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="20" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{DynamicResource Loc.ServiceSettings.Subtitle}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <CheckBox Content="{DynamicResource Loc.Common.Enabled}"
                      IsChecked="{Binding Enabled}" />
            <CheckBox Margin="0,10,0,0"
                      Content="{DynamicResource Loc.ServiceSettings.AutoStart}"
                      IsChecked="{Binding AutoStart}" />
            <CheckBox Margin="0,10,0,0"
                      Content="{DynamicResource Loc.ServiceSettings.AutoRestart}"
                      IsChecked="{Binding Supervise}" />

            <TextBlock Margin="0,16,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       Text="{DynamicResource Loc.ServiceSettings.ActivePackage}" />
            <TextBlock Margin="0,4,0,0"
                       FontWeight="SemiBold"
                       Text="{Binding ActivePackageLabel}" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       Text="{DynamicResource Loc.ServiceSettings.PackageHint}"
                       TextWrapping="Wrap" />

            <StackPanel Margin="0,16,0,0"
                        Visibility="{Binding ShowNetworkFields, Converter={StaticResource BoolToVis}}">
                <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{DynamicResource Loc.ServiceSettings.Host}" />
                <TextBox Margin="0,6,0,0"
                         Padding="10,6"
                         FlowDirection="LeftToRight"
                         Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{DynamicResource Loc.ServiceSettings.Port}" />
                <TextBox Margin="0,6,0,0"
                         Padding="10,6"
                         FlowDirection="LeftToRight"
                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Margin="0,12,0,0"
                        Visibility="{Binding ShowSslFields, Converter={StaticResource BoolToVis}}">
                <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                           Text="{DynamicResource Loc.ServiceSettings.SslPort}" />
                <TextBox Margin="0,6,0,0"
                         Padding="10,6"
                         FlowDirection="LeftToRight"
                         Text="{Binding SslPort, UpdateSourceTrigger=PropertyChanged}" />
                <CheckBox Margin="0,10,0,0"
                          Content="{DynamicResource Loc.ServiceSettings.EnableHttps}"
                          IsChecked="{Binding SslEnabled}" />
            </StackPanel>

            <Button Margin="0,16,0,0"
                    HorizontalAlignment="Left"
                    Padding="12,6"
                    Visibility="{Binding ShowNginxHttpSettings, Converter={StaticResource BoolToVis}}"
                    Content="{DynamicResource Loc.ServiceSettings.HttpPerformance}"
                    Command="{Binding OpenNginxHttpSettingsCommand}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <TextBlock Foreground="{StaticResource StackrootTextMutedBrush}"
                       FontSize="12"
                       MinHeight="16"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
            <DockPanel Margin="0,12,0,0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="88"
                            Margin="0,0,8,0"
                            Content="{DynamicResource Loc.Common.Close}"
                            Command="{Binding CloseCommand}" />
                    <Button Width="88"
                            Content="{DynamicResource Loc.Common.Save}"
                            Style="{StaticResource StackrootPrimaryButtonStyle}"
                            Command="{Binding SaveCommand}" />
                </StackPanel>
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
