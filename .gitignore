# OS
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Secrets (keep local only)
.env
.env.*
!.env.example


# Locked installer leftovers at repo root
/packages/

# Node / pnpm (legacy tooling; should not land in this repo)
node_modules/
.pnpm/
.pnpm-store/
package-lock.json
pnpm-lock.yaml
yarn.lock

# Scratch / local experiments
tmp/**
tmp-*.csx
scratch/

# Portable NSIS toolchain (local only)
resources/tools/nsis/

# Downloaded at build time by scripts/ensure-pie.ps1
resources/packages/pie.phar

# Offline .NET prerequisite (downloaded when packing releases)
installer/prerequisites/*.exe

# Pinned launcher — binary is rebuilt locally; protocol file stays in git
installer/pinned/Stackroot.exe
installer/pinned/_build/
installer/pinned/_probe*/
installer/pinned/*.pdb
# Local log files
*.log

